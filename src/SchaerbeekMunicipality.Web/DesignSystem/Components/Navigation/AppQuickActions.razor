<MudGrid Spacing="3">
    @foreach (var action in Actions)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudButton Href="@action.Href"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       FullWidth="true"
                       StartIcon="@action.Icon"
                       Style="min-height: 56px; justify-content: flex-start;">
                @action.Label
            </MudButton>
        </MudItem>
    }
</MudGrid>

@code {
    [Parameter] [EditorRequired] public IReadOnlyList<AppQuickAction> Actions { get; set; } = [];

    public sealed record AppQuickAction(string Label, string Href, string Icon);

}