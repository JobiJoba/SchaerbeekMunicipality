@using SchaerbeekMunicipality.Web.DesignSystem.Tokens

<MudCard Elevation="@SchaerbeekElevation.Card"
         Class="@Class"
         Style="@CardStyle">
    @if (Accent)
    {
        <div style="height: 4px; background: @SchaerbeekColors.Accent; border-radius: 4px 4px 0 0;"></div>
    }
    <MudCardContent Class="pa-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Spacing="1">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Label</MudText>
                <MudText Typo="Typo.h4">@DisplayText</MudText>
            </MudStack>
            @if (!string.IsNullOrWhiteSpace(Icon))
            {
                <MudIcon Icon="@Icon" Color="Color.Primary" Size="Size.Large" />
            }
        </MudStack>
    </MudCardContent>
    @if (!string.IsNullOrWhiteSpace(Href))
    {
        <MudCardActions Class="pa-2 pt-0">
            <MudButton Href="@Href" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">
                View
            </MudButton>
        </MudCardActions>
    }
</MudCard>

@code {
    [Parameter, EditorRequired]
    public string Label { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public int Value { get; set; }

    [Parameter]
    public string? Icon { get; set; }

    [Parameter]
    public bool Accent { get; set; }

    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string? FormattedValue { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    private string DisplayText => FormattedValue ?? Value.ToString("N0");

    private string CardStyle =>
        string.IsNullOrWhiteSpace(Style)
            ? "border: 1px solid var(--mud-palette-lines-default);"
            : Style;
}
