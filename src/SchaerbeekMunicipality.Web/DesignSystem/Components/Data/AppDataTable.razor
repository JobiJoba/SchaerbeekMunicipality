@typeparam T

@if (Loading)
{
    @for (var i = 0; i < SkeletonRows; i++)
    {
        <MudSkeleton Height="40px" Class="mb-2" />
    }
}
else if (Items is null || !Items.Any())
{
    @if (EmptyState is not null)
    {
        @EmptyState
    }
    else
    {
        <AppEmptyState Title="No records" Description="Nothing to display yet." />
    }
}
else
{
    <MudTable T="T"
              Items="@Items"
              Dense="true"
              Hover="true"
              Striped="true"
              Elevation="@SchaerbeekElevation.Flat"
              Outlined="true"
              Breakpoint="Breakpoint.Sm"
              RowClass="cursor-pointer"
              OnRowClick="HandleRowClick"
              RowsPerPage="@PageSize"
              Class="@Class"
              Style="@Style">
        <HeaderContent>@HeaderContent</HeaderContent>
        <RowTemplate Context="row">
            @RowTemplate(row)
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="@(new int[] { 10, 25, 50 })" />
        </PagerContent>
    </MudTable>
}

@code {
    [Parameter]
    public IEnumerable<T>? Items { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    [Parameter]
    public RenderFragment? HeaderContent { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment<T> RowTemplate { get; set; } = null!;

    [Parameter]
    public EventCallback<T> OnRowClick { get; set; }

    [Parameter]
    public RenderFragment? EmptyState { get; set; }

    [Parameter, EditorRequired]
    public string Caption { get; set; } = string.Empty;

    [Parameter]
    public bool AllowPaging { get; set; } = true;

    [Parameter]
    public int PageSize { get; set; } = 25;

    [Parameter]
    public int SkeletonRows { get; set; } = 5;

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    private async Task HandleRowClick(TableRowClickEventArgs<T> args)
    {
        if (OnRowClick.HasDelegate)
        {
            await OnRowClick.InvokeAsync(args.Item);
        }
    }
}
