<MudStack Row="true" AlignItems="AlignItems.Start" Wrap="Wrap.Wrap" Class="@HeaderClass" Style="@Style">
    <MudStack Spacing="1" Class="flex-grow-1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h1" Class="mb-0">@Title</MudText>
            @if (StatusChip is not null)
            {
                @StatusChip
            }
        </MudStack>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <MudText Typo="Typo.body1" Color="Color.Secondary">@Subtitle</MudText>
        }
    </MudStack>
    @if (Actions is not null)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2 mt-sm-0">
            @Actions
        </MudStack>
    }
</MudStack>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Subtitle { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public RenderFragment? StatusChip { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    private string HeaderClass => new CssBuilder("mb-8")
        .AddClass(Class)
        .Build();
}
