<MudPaper Elevation="@SchaerbeekElevation.Overlay"
          Class="@BarClass"
          Style="@Style">
    <MudToolBar Dense="true" Gutters="false" Class="gap-2 pa-4 justify-end">
        @ChildContent
    </MudToolBar>
</MudPaper>

@code {
    [Parameter] public bool Sticky { get; set; } = true;

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string? Class { get; set; }

    [Parameter] public string? Style { get; set; }

    private string BarClass => new CssBuilder()
        .AddClass("app-action-bar", Sticky)
        .AddClass(Class)
        .Build();

}

<style>
    .app-action-bar {
        position: sticky;
        bottom: 0;
        z-index: 100;
        border-top: 1px solid var(--mud-palette-lines-default);
    }
</style>