<MudCard Elevation="@Elevation" Outlined="@Outlined" Class="@Class" Style="@Style">
    <MudCardContent Class="pa-4">
        @if (HasHeader)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    @if (!string.IsNullOrWhiteSpace(Icon))
                    {
                        <MudIcon Icon="@Icon" Color="Color.Primary" />
                    }
                    @if (!string.IsNullOrWhiteSpace(Title))
                    {
                        <MudText Typo="Typo.h3">@Title</MudText>
                    }
                </MudStack>
                @if (HeaderActions is not null)
                {
                    @HeaderActions
                }
            </MudStack>
        }
        @ChildContent
    </MudCardContent>
    @if (Actions is not null)
    {
        <MudCardActions Class="justify-end pa-4 pt-0">
            @Actions
        </MudCardActions>
    }
</MudCard>

@code {
    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Icon { get; set; }

    [Parameter]
    public RenderFragment? HeaderActions { get; set; }

    [Parameter]
    public bool Outlined { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    private int Elevation => Outlined ? SchaerbeekElevation.Flat : SchaerbeekElevation.Card;

    private bool HasHeader =>
        !string.IsNullOrWhiteSpace(Title) ||
        !string.IsNullOrWhiteSpace(Icon) ||
        HeaderActions is not null;
}
