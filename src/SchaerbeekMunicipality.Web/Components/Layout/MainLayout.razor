@inherits LayoutComponentBase
@implements IDisposable
@using SchaerbeekMunicipality.Web.Auth
@using SchaerbeekMunicipality.Web.DesignSystem.Components.Navigation
@using SchaerbeekMunicipality.Web.DesignSystem.Tokens
@using SchaerbeekMunicipality.Web.DesignSystem.Theme
@using SchaerbeekMunicipality.Web.Auth.Components
@using Microsoft.Extensions.DependencyInjection
@using SchaerbeekMunicipality.Web.Features.Registration.ListPendingPoliceVerifications
@inject ICurrentOfficer CurrentOfficer
@inject IWebHostEnvironment HostEnvironment
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Navigation

<a href="#main" class="skip-link">Skip to main content</a>

<MudThemeProvider Theme="SchaerbeekTheme.Default" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <AppTopNavigation Title="Schaerbeek — Population Department"
                      OfficerDisplayName="@CurrentOfficer.DisplayName"
                      OnMenuToggle="ToggleDrawer">
        <TrailingContent>
            <RoleSwitcher />
        </TrailingContent>
    </AppTopNavigation>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="@SchaerbeekElevation.Flat"
               Variant="DrawerVariant.Responsive"
               Style="border-right: 1px solid var(--mud-palette-lines-default);">
        <AppSideNavigation Items="_navItems" CurrentRole="@CurrentOfficer.Role" />
    </MudDrawer>

    <MudMainContent Class="app-main-content">
        <div class="app-main-body">
            @Body
        </div>
        <AppFooter>
            Schaerbeek – Schaarbeek · Population Department · @HostEnvironment.EnvironmentName
        </AppFooter>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private IReadOnlyList<AppNavItem> _navItems = [];

    protected override void OnInitialized()
    {
        if (DemoOfficerPersistence.TryGetOfficerId(Navigation, out var officerId))
        {
            CurrentOfficer.RestoreOfficer(officerId);
        }

        CurrentOfficer.Changed += OnOfficerChanged;

        _ = RefreshNavItemsAsync();
    }

    private async Task RefreshNavItemsAsync()
    {
        var pendingCount = 0;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var handler = scope.ServiceProvider.GetRequiredService<ListPendingPoliceVerificationsHandler>();
            var pending = await handler.Handle(CancellationToken.None);
            pendingCount = pending.TotalCount;
        }
        catch
        {
            pendingCount = 0;
        }

        var items = new List<AppNavItem>();

        if (CurrentOfficer.Role != OfficerRole.PopulationOfficer)
        {
            items.Add(new AppNavItem("Home", "/", Icons.Material.Outlined.Home));
        }

        if (CurrentOfficer.Role == OfficerRole.ReceptionOfficer)
        {
            items.Add(new AppNavItem("New case", "/registration/new-case", Icons.Material.Outlined.Add));
        }
        else if (CurrentOfficer.Role == OfficerRole.PopulationOfficer)
        {
            items.AddRange(
            [
                new AppNavItem("Review dashboard", "/registration/review-dashboard", Icons.Material.Outlined.Dashboard),
                new AppNavItem("Registration cases", "/registration/cases", Icons.Material.Outlined.FolderOpen),
                new AppNavItem("Birth declarations", "/birth-declarations", Icons.Material.Outlined.ChildCare),
                new AppNavItem(
                    "Outbound notifications",
                    "/administration/outbound-notifications",
                    Icons.Material.Outlined.Send),
            ]);
        }
        else if (CurrentOfficer.Role == OfficerRole.PoliceClerk)
        {
            items.Add(new AppNavItem(
                "Police verifications",
                "/registration/police-verifications",
                Icons.Material.Outlined.LocalPolice,
                OfficerRole.PoliceClerk.ToString(),
                pendingCount > 0 ? pendingCount : null));
        }
        else
        {
            items.AddRange(
            [
                new AppNavItem("Review dashboard", "/registration/review-dashboard", Icons.Material.Outlined.Dashboard),
                new AppNavItem("Registration cases", "/registration/cases", Icons.Material.Outlined.FolderOpen),
                new AppNavItem("Birth declarations", "/birth-declarations", Icons.Material.Outlined.ChildCare),
            ]);
        }

        if (HostEnvironment.IsDevelopment())
        {
            items.Add(new AppNavItem("Design system", "/design-system", Icons.Material.Outlined.Palette));
        }

        _navItems = items;
        await InvokeAsync(StateHasChanged);
    }

    private void OnOfficerChanged()
    {
        _ = RefreshNavItemsAsync();
        var targetUri = DemoOfficerPersistence.AppendToUri(
            ResolveUriAfterRoleSwitch(),
            CurrentOfficer.OfficerId);
        Navigation.NavigateTo(targetUri, forceLoad: true);
    }

    private string ResolveUriAfterRoleSwitch()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?')[0].TrimEnd('/');

        return CurrentOfficer.Role switch
        {
            OfficerRole.ReceptionOfficer when IsPopulationOnlyPath(path) || path is "registration/police-verifications" =>
                "/registration/new-case",
            OfficerRole.PoliceClerk when IsPopulationOnlyPath(path) || path is "registration/new-case" =>
                "/registration/police-verifications",
            OfficerRole.PopulationOfficer when path is "" or "home" or "registration/new-case" or "registration/police-verifications" =>
                "/registration/review-dashboard",
            _ => Navigation.Uri,
        };
    }

    private static bool IsPopulationOnlyPath(string path) =>
        path is "registration/cases" or "registration/review-dashboard" or "birth-declarations" ||
        path.StartsWith("registration/cases/", StringComparison.OrdinalIgnoreCase) ||
        path.StartsWith("birth-declarations/", StringComparison.OrdinalIgnoreCase) ||
        path.StartsWith("administration/outbound-notifications", StringComparison.OrdinalIgnoreCase);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    public void Dispose()
    {
        CurrentOfficer.Changed -= OnOfficerChanged;
    }
}
