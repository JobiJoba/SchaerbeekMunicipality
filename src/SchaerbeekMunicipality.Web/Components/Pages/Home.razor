@page "/"
@page "/home"

<AppPage Title="Population Department">
    <AppPageHeader Title="Population Department"
                   Subtitle="Educational simulation of Belgian municipal population registration workflows." />

    <AppSection>
        <AppCard Title="Four core decisions" Icon="@Icons.Material.Outlined.Gavel">
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Outlined.Person">Identity established with sufficient certainty</MudListItem>
                <MudListItem Icon="@Icons.Material.Outlined.Gavel">Legal basis to reside in Belgium</MudListItem>
                <MudListItem Icon="@Icons.Material.Outlined.Home">Genuine residence at declared address</MudListItem>
                <MudListItem Icon="@Icons.Material.Outlined.Badge">Correct register and legal status</MudListItem>
            </MudList>
        </AppCard>
    </AppSection>

    <MudButton Href="/registration/cases"
               Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Outlined.FolderOpen"
               Style="min-height: 48px;">
        View registration cases
    </MudButton>
</AppPage>
