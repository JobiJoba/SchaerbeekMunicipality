@using SchaerbeekMunicipality.Application.Auth
@inject ICurrentOfficer CurrentOfficer

<div class="role-switcher">
    <MudSelect T="Guid"
               Value="CurrentOfficer.OfficerId"
               ValueChanged="OnOfficerChanged"
               Dense="true"
               FullWidth="false"
               Variant="Variant.Outlined"
               Style="background: var(--mud-palette-surface);">
        @foreach (var officer in DemoOfficers.All)
        {
            <MudSelectItem Value="officer.Id">@officer.DisplayName</MudSelectItem>
        }
    </MudSelect>
</div>

@code {
    private void OnOfficerChanged(Guid officerId) =>
        CurrentOfficer.SelectOfficer(officerId);
}
