@using SchaerbeekMunicipality.Domain.ChangeOfAddress
@using SchaerbeekMunicipality.Application.Features.ChangeOfAddress.OpenChangeOfAddressCase
@using SchaerbeekMunicipality.Application.Features.ChangeOfAddress.ResolveRegisteredPerson
@using SchaerbeekMunicipality.Application.Features.Registration.SearchNationalRegister

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h4">New change of address</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Search the National Register to identify a registered resident.
        </MudText>

        <NationalRegisterSearchForm ShowBirthDateColumn="false"
                                    NumberColumnTitle="NR number"
                                    SearchAsync="SearchAsync">
            <RowActions Context="match">
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           Disabled="_opening || string.IsNullOrWhiteSpace(match.NationalRegisterNumber)"
                           OnClick="@(() => OpenCase(match))">
                    Open case
                </MudButton>
            </RowActions>
        </NationalRegisterSearchForm>

        @if (!string.IsNullOrWhiteSpace(_actionError))
        {
            <AppAlert Severity="Severity.Error" Title="Error" Class="mt-4">@_actionError</AppAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public SearchNationalRegisterHandler SearchHandler { get; set; } = null!;
    [Parameter] public ResolveRegisteredPersonHandler ResolveHandler { get; set; } = null!;
    [Parameter] public OpenChangeOfAddressCaseHandler OpenHandler { get; set; } = null!;

    private bool _opening;
    private string? _actionError;

    private async Task<IReadOnlyList<NationalRegisterSearchMatch>> SearchAsync(NrSearchFormCriteria criteria)
    {
        var response = await SearchHandler.Handle(
            new SearchNationalRegisterRequest(criteria.GivenName, criteria.FamilyName, criteria.BirthDate),
            CancellationToken.None);

        return response.Matches.Select(Map).ToList();
    }

    private async Task OpenCase(NationalRegisterSearchMatch match)
    {
        _opening = true;
        _actionError = null;
        try
        {
            var resolved = await ResolveHandler.Handle(
                new ResolveRegisteredPersonRequest(match.RegisterPersonId),
                CancellationToken.None);

            var opened = await OpenHandler.Handle(
                new OpenChangeOfAddressCaseRequest(resolved.PersonId),
                CancellationToken.None);

            MudDialog.Close(DialogResult.Ok(opened.CaseId));
        }
        catch (Exception ex) when (ex is InvalidChangeOfAddressTransitionException or KeyNotFoundException or FluentValidation.ValidationException)
        {
            _actionError = ex is FluentValidation.ValidationException validation
                ? string.Join(" ", validation.Errors.Select(e => e.ErrorMessage))
                : ex.Message;
        }
        finally
        {
            _opening = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private static NationalRegisterSearchMatch Map(NationalRegisterMatchDto match) =>
        new(
            match.RegisterPersonId,
            match.GivenName,
            match.FamilyName,
            match.BirthDate,
            match.BisNumber,
            match.NationalRegisterNumber,
            match.MatchScore,
            match.MatchReason);
}
