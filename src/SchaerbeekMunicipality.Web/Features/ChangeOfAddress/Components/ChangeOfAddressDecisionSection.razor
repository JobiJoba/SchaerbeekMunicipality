@using SchaerbeekMunicipality.Application.Features.ChangeOfAddress.GetChangeOfAddressCase
@using SchaerbeekMunicipality.Application.Features.ChangeOfAddress.GetChangeOfAddressChecklist
@using SchaerbeekMunicipality.Application.Features.ChangeOfAddress.RejectChangeOfAddress
@using SchaerbeekMunicipality.Domain.ChangeOfAddress
@using SchaerbeekMunicipality.Web.Api.ChangeOfAddress
@inject IChangeOfAddressApi ChangeOfAddressApi
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<AppCard Title="Officer decision" Outlined="true">
    @if (_checklist is not null)
    {
        <OfficerDecisionChecklist Items="@MapChecklist(_checklist)"/>
    }

    @if (Case.Status == ChangeOfAddressCaseStatus.Confirmed)
    {
        <AppAlert Severity="Severity.Success" Title="Address change confirmed">
            Domicile updated for @Case.PersonGivenName @Case.PersonFamilyName
        </AppAlert>
    }
    else if (Case.Status == ChangeOfAddressCaseStatus.Rejected)
    {
        <AppAlert Severity="Severity.Error" Title="Case rejected">@Case.RejectionReason — @Case.DecisionNotes</AppAlert>
    }
    else if (Case.Status == ChangeOfAddressCaseStatus.AwaitingPoliceVerification)
    {
        <AppAlert Severity="Severity.Warning" Title="Awaiting police verification">
            Police verification is pending for the new address.
        </AppAlert>
    }

    @if (CanDecide || CanReject)
    {
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" Class="mt-4">
            @if (CanDecide)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Outlined.CheckCircle"
                           Disabled="_busy || !Case.ReadyForConfirmation || Case.Status == ChangeOfAddressCaseStatus.AwaitingPoliceVerification"
                           OnClick="Confirm">
                    Confirm address change
                </MudButton>
            }
            @if (CanReject)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           Disabled="_busy"
                           OnClick="OpenRejectDialog">
                    Close case
                </MudButton>
            }
        </MudStack>
    }
</AppCard>

@code {
    [Parameter] public ChangeOfAddressCaseDetailDto Case { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private ChangeOfAddressChecklistResponse? _checklist;
    private bool _busy;

    private bool CanDecide =>
        CurrentOfficer.CanApproveRegistration &&
        Case.CanEdit &&
        Case.Status is ChangeOfAddressCaseStatus.Intake
            or ChangeOfAddressCaseStatus.UnderReview
            or ChangeOfAddressCaseStatus.AwaitingPoliceVerification;

    private bool CanReject =>
        CurrentOfficer.CanApproveRegistration &&
        Case.CanEdit &&
        Case.Status is ChangeOfAddressCaseStatus.Intake
            or ChangeOfAddressCaseStatus.UnderReview
            or ChangeOfAddressCaseStatus.AwaitingPoliceVerification;

    [Inject] private ICurrentOfficer CurrentOfficer { get; set; } = null!;

    protected override void OnParametersSet()
    {
        _checklist = ChangeOfAddressChecklistMapper.FromCaseDetail(Case);
    }

    private async Task Confirm()
    {
        _busy = true;
        try
        {
            await ChangeOfAddressApi.ConfirmAsync(Case.Id, CancellationToken.None);
            Snackbar.Add("Address change confirmed.", Severity.Success);
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OpenRejectDialog()
    {
        var parameters = new DialogParameters<RejectChangeOfAddressDialog>
        {
            { x => x.InitialReason, ChangeOfAddressRejectionReason.OpenedInError }
        };

        var dialog = await DialogService.ShowAsync<RejectChangeOfAddressDialog>(
            "Close change of address case",
            parameters,
            AppDialogOptions.Small);

        var result = await dialog.Result;
        if (result is { Canceled: false } && result.Data is RejectChangeOfAddressRequest request)
        {
            await RejectAsync(request);
        }
    }

    private async Task RejectAsync(RejectChangeOfAddressRequest request)
    {
        _busy = true;
        try
        {
            await ChangeOfAddressApi.RejectAsync(Case.Id, request, CancellationToken.None);
            Snackbar.Add("Case closed.", Severity.Warning);
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private static IReadOnlyList<AppChecklistItem> MapChecklist(ChangeOfAddressChecklistResponse checklist)
    {
        return checklist.Questions
            .Select(q => new AppChecklistItem(q.Question, q.IsSatisfied, q.BlockingReason))
            .ToList();
    }

}
