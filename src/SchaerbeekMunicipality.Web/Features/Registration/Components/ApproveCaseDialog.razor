<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4">
            Select the register where this person will be entered upon registration confirmation.
        </MudText>
        <MudSelect T="RegisterTarget"
                   @bind-Value="_registerTarget"
                   Label="Register target"
                   Required="true">
            @foreach (var target in Enum.GetValues<RegisterTarget>())
            {
                <MudSelectItem T="RegisterTarget" Value="target">@FormatRegisterTarget(target)</MudSelectItem>
            }
        </MudSelect>
        @if (!string.IsNullOrWhiteSpace(SuggestedRegisterTarget))
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                Suggested: @SuggestedRegisterTarget
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm">Approve</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string? SuggestedRegisterTarget { get; set; }

    private RegisterTarget _registerTarget = RegisterTarget.ForeignersRegister;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(SuggestedRegisterTarget)
            && Enum.TryParse<RegisterTarget>(SuggestedRegisterTarget, out var parsed))
        {
            _registerTarget = parsed;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Confirm()
    {
        MudDialog.Close(DialogResult.Ok(_registerTarget));
    }

    private static string FormatRegisterTarget(RegisterTarget target)
    {
        return target switch
        {
            RegisterTarget.PopulationRegister => "Population register",
            RegisterTarget.ForeignersRegister => "Foreigners register",
            RegisterTarget.WaitingRegister => "Waiting register",
            RegisterTarget.SpecialRegister => "Special register",
            _ => target.ToDisplayString()
        };
    }

}