@using SchaerbeekMunicipality.Domain.Identity
@using SchaerbeekMunicipality.Web.DesignSystem.Components.Dialogs
@using SchaerbeekMunicipality.Application.Features.Registration.GetRegistrationCase
@using SchaerbeekMunicipality.Application.Features.Registration.RecordCivilStatus
@inject RecordCivilStatusHandler RecordCivilStatusHandler
@inject FluentValidation.IValidator<RecordCivilStatusRequest> CivilStatusValidator
@inject IAppDialogService DialogService
@inject ISnackbar Snackbar

<AppEditableSection Title="Civil status"
                    PrerequisiteMet="_case.Checklist.IdentityEstablished"
                    HasData="_case.CivilStatus is not null"
                    IsEditing="_editing"
                    CanEdit="CanEdit"
                    EditAriaLabel="Edit civil status"
                    OnStartEdit="StartEditing">
    <PrerequisiteContent>
        <AppInfoBox>
            Record identity before capturing civil status.
        </AppInfoBox>
    </PrerequisiteContent>
    <EditContent>
        <MudForm @ref="_form"
                 @bind-IsValid="_formValid"
                 Model="_model"
                 Validation="@(CivilStatusValidator.ToMudValidateValue<RecordCivilStatusRequest, CivilStatusFormModel>(MapCivilStatusRequest))">
            <AppFormSection Title="Marital status">
                <MudItem xs="12" md="6">
                    <MudSelect T="CivilStatus?"
                               @bind-Value="_model.Status"
                               Label="Civil status"
                               Required="true"
                               ToStringFunc="@FormatStatus">
                        <MudSelectItem T="CivilStatus?" Value="CivilStatus.Single">Single</MudSelectItem>
                        <MudSelectItem T="CivilStatus?" Value="CivilStatus.Married">Married</MudSelectItem>
                        <MudSelectItem T="CivilStatus?" Value="CivilStatus.Divorced">Divorced</MudSelectItem>
                        <MudSelectItem T="CivilStatus?" Value="CivilStatus.Widowed">Widowed</MudSelectItem>
                        <MudSelectItem T="CivilStatus?" Value="CivilStatus.Separated">Separated</MudSelectItem>
                        <MudSelectItem T="CivilStatus?" Value="CivilStatus.RegisteredPartnership">Registered partnership</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </AppFormSection>

            @if (RequiresMarriageDetails(_model.Status))
            {
                <AppFormSection Title="Marriage / partnership details">
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.SpouseGivenName" Label="Spouse given name" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.SpouseFamilyName" Label="Spouse family name" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <AppDateField @bind-Value="_model.MarriageDate"
                                      For="@(() => _model.MarriageDate)"
                                      Label="Marriage date"
                                      Required="true"
                                      MaxDate="@DateTime.Today" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.MarriagePlace" Label="Marriage place" />
                    </MudItem>
                    @if (RequiresMarriageRecognition(_model.MarriagePlace))
                    {
                        <MudItem xs="12" md="6">
                            <MudSelect T="MarriageRecognitionStatus"
                                       @bind-Value="_model.MarriageRecognitionStatus"
                                       Label="Marriage recognition"
                                       Required="true"
                                       ToStringFunc="@FormatRecognitionStatus">
                                <MudSelectItem Value="MarriageRecognitionStatus.PendingRecognition">Pending recognition</MudSelectItem>
                                <MudSelectItem Value="MarriageRecognitionStatus.Recognised">Recognised</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    }
                </AppFormSection>
            }

            <AppSaveCancelBar SaveText="@(_editing ? "Save changes" : "Record civil status")"
                              CancelText="@(_editing ? "Cancel" : "Clear")"
                              Saving="_saving"
                              Disabled="@(_editing && !FormDirty)"
                              OnSave="Save"
                              OnCancel="HandleCancel" />
        </MudForm>
    </EditContent>
    <ReadContent>
        <MudText Typo="Typo.body1">@FormatStatus(_case.CivilStatus!.Status)</MudText>
        @if (_case.CivilStatus!.EffectiveRegisterStatus != _case.CivilStatus!.Status)
        {
            <MudText Typo="Typo.body2" Color="Color.Warning" Class="mt-1">
                Register status: @FormatStatus(_case.CivilStatus!.EffectiveRegisterStatus) (marriage recognition pending)
            </MudText>
        }
        @if (_case.MarriageRecognitionBlocking)
        {
            <AppAlert Severity="Severity.Warning" Title="Marriage not yet recognised" Class="mt-3">
                Foreign marriage recognition is pending. The person remains single for register purposes until recognition is complete — consider suspending the case.
            </AppAlert>
        }
        @if (RequiresMarriageDetails(_case.CivilStatus!.Status))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                @_case.CivilStatus!.SpouseGivenName @_case.CivilStatus!.SpouseFamilyName
                @if (_case.CivilStatus!.MarriageDate is { } marriageDate)
                {
                    <span> · married @marriageDate.ToString("d")</span>
                }
                @if (!string.IsNullOrWhiteSpace(_case.CivilStatus!.MarriagePlace))
                {
                    <span> · @_case.CivilStatus!.MarriagePlace</span>
                }
            </MudText>
        }
    </ReadContent>
</AppEditableSection>

@code {
    [Parameter, EditorRequired]
    public RegistrationCaseDetailDto Case { get; set; } = null!;

    [Parameter, EditorRequired]
    public Guid CaseId { get; set; }

    [Parameter]
    public bool CanEdit { get; set; }

    [Parameter]
    public EventCallback OnUpdated { get; set; }

    private RegistrationCaseDetailDto _case = null!;
    private bool _editing;
    private readonly CivilStatusFormModel _model = new();
    private MudForm _form = null!;
    private bool _formValid;
    private bool _saving;

    protected override void OnParametersSet()
    {
        _case = Case;
        _editing = false;
    }

    private bool FormDirty =>
        _case.CivilStatus is not null &&
        (_model.Status != _case.CivilStatus.Status ||
         _model.SpouseGivenName != _case.CivilStatus.SpouseGivenName ||
         _model.SpouseFamilyName != _case.CivilStatus.SpouseFamilyName ||
         _model.MarriageDate != _case.CivilStatus.MarriageDate ||
         _model.MarriagePlace != _case.CivilStatus.MarriagePlace ||
         _model.MarriageRecognitionStatus != _case.CivilStatus.MarriageRecognitionStatus);

    private static RecordCivilStatusRequest MapCivilStatusRequest(CivilStatusFormModel model) =>
        new(
            model.Status ?? default,
            model.SpouseGivenName,
            model.SpouseFamilyName,
            model.MarriageDate,
            model.MarriagePlace,
            model.MarriageRecognitionStatus);

    private static bool RequiresMarriageDetails(CivilStatus? status) =>
        status is CivilStatus.Married or CivilStatus.RegisteredPartnership;

    private static bool RequiresMarriageRecognition(string? marriagePlace) =>
        !string.IsNullOrWhiteSpace(marriagePlace)
        && !marriagePlace.Contains("Belgium", StringComparison.OrdinalIgnoreCase)
        && !marriagePlace.Contains("België", StringComparison.OrdinalIgnoreCase)
        && !marriagePlace.Contains("Belgique", StringComparison.OrdinalIgnoreCase);

    private static string FormatRecognitionStatus(MarriageRecognitionStatus status) =>
        status switch
        {
            MarriageRecognitionStatus.Recognised => "Recognised",
            MarriageRecognitionStatus.PendingRecognition => "Pending recognition",
            _ => "Not applicable",
        };

    private static string FormatStatus(CivilStatus? status) =>
        status switch
        {
            CivilStatus.Single => "Single",
            CivilStatus.Married => "Married",
            CivilStatus.Divorced => "Divorced",
            CivilStatus.Widowed => "Widowed",
            CivilStatus.Separated => "Separated",
            CivilStatus.RegisteredPartnership => "Registered partnership",
            _ => "Select status",
        };

    private void StartEditing()
    {
        if (_case.CivilStatus is null)
        {
            return;
        }

        _model.Status = _case.CivilStatus.Status;
        _model.SpouseGivenName = _case.CivilStatus.SpouseGivenName;
        _model.SpouseFamilyName = _case.CivilStatus.SpouseFamilyName;
        _model.MarriageDate = _case.CivilStatus.MarriageDate;
        _model.MarriagePlace = _case.CivilStatus.MarriagePlace;
        _model.MarriageRecognitionStatus = _case.CivilStatus.MarriageRecognitionStatus;
        _editing = true;
    }

    private async Task CancelEditing()
    {
        if (FormDirty)
        {
            var confirmed = await DialogService.ConfirmAsync(
                "Discard changes?",
                "You have unsaved civil status changes.",
                "Discard");

            if (!confirmed)
            {
                return;
            }
        }

        _editing = false;
    }

    private void ClearForm()
    {
        _model.Status = null;
        _model.SpouseGivenName = null;
        _model.SpouseFamilyName = null;
        _model.MarriageDate = null;
        _model.MarriagePlace = null;
        _model.MarriageRecognitionStatus = MarriageRecognitionStatus.NotApplicable;
    }

    private async Task HandleCancel()
    {
        if (_editing)
        {
            await CancelEditing();
        }
        else
        {
            ClearForm();
        }
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_formValid || _model.Status is null)
        {
            return;
        }

        if (RequiresMarriageDetails(_model.Status) && _model.MarriageDate is null)
        {
            return;
        }

        _saving = true;
        try
        {
            await RecordCivilStatusHandler.Handle(
                new Domain.Registration.RegistrationCaseId(CaseId),
                MapCivilStatusRequest(_model) with
                {
                    MarriageRecognitionStatus = RequiresMarriageRecognition(_model.MarriagePlace)
                        ? _model.MarriageRecognitionStatus
                        : MarriageRecognitionStatus.NotApplicable
                },
                CancellationToken.None);

            _editing = false;
            Snackbar.Add("Civil status saved.", Severity.Success);
            await OnUpdated.InvokeAsync();
        }
        catch (FluentValidation.ValidationException ex)
        {
            Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error);
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed class CivilStatusFormModel
    {
        public CivilStatus? Status { get; set; }
        public string? SpouseGivenName { get; set; }
        public string? SpouseFamilyName { get; set; }
        public DateOnly? MarriageDate { get; set; }
        public string? MarriagePlace { get; set; }
        public MarriageRecognitionStatus MarriageRecognitionStatus { get; set; } = MarriageRecognitionStatus.NotApplicable;
    }
}