@using FluentValidation
@using SchaerbeekMunicipality.Application.Features.Registration.GetRegistrationCase
@using SchaerbeekMunicipality.Application.Features.Registration.RecordImmigrationDecision
@using SchaerbeekMunicipality.Application.Features.Registration.RecordResidencePermit
@using SchaerbeekMunicipality.Application.Features.Registration.SetResidenceCategory
@using SchaerbeekMunicipality.Domain.Immigration
@using SchaerbeekMunicipality.Web.Api.Registration
@using Severity = MudBlazor.Severity
@inject IRegistrationApi RegistrationApi
@inject IValidator<RecordResidencePermitRequest> ResidencePermitValidator
@inject IValidator<RecordImmigrationDecisionRequest> ImmigrationDecisionValidator
@inject IValidator<SetResidenceCategoryRequest> ResidenceCategoryValidator
@inject IAppDialogService DialogService
@inject ISnackbar Snackbar

@if (!_case.Checklist.IdentityEstablished)
{
    <AppInfoBox>
        Record identity before classifying legal residence.
    </AppInfoBox>
}
else if (_case.ResidenceCategory is null)
{
    @if (CanEdit)
    {
        <AppCard Title="Residence category" Outlined="true">
            <MudForm @ref="_categoryForm"
                     @bind-IsValid="_categoryFormValid"
                     Model="_categoryModel"
                     Validation="@(ResidenceCategoryValidator.ToMudValidateValue<SetResidenceCategoryRequest, CategoryFormModel>(MapCategoryRequest))">
                <AppFormSection Title="Why is the person in Belgium?">
                    <MudItem xs="12" md="8">
                        <MudSelect T="ResidenceCategory?"
                                   @bind-Value="_categoryModel.Category"
                                   Label="Residence category"
                                   Required="true"
                                   ToStringFunc="@FormatCategory">
                            <MudSelectItem T="ResidenceCategory?" Value="ResidenceCategory.EuCitizen">EU citizen</MudSelectItem>
                            <MudSelectItem T="ResidenceCategory?" Value="ResidenceCategory.NonEuWorker">Non-EU worker</MudSelectItem>
                            <MudSelectItem T="ResidenceCategory?" Value="ResidenceCategory.Student">Student</MudSelectItem>
                            <MudSelectItem T="ResidenceCategory?" Value="ResidenceCategory.Refugee">Refugee / temporary protection</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </AppFormSection>

                <AppInfoBox Class="mb-4">
                    EU citizens need a passport or national ID on file. Non-EU workers and students must record a valid permit plus identity document. Refugees require a federal protection decision.
                </AppInfoBox>

                <AppSaveCancelBar SaveText="Set category"
                                  CancelText="Clear"
                                  Saving="_savingCategory"
                                  OnSave="SaveCategory"
                                  OnCancel="HandleCategoryCancel"/>
            </MudForm>
        </AppCard>
    }
    else
    {
        <AppCard Title="Residence category" Outlined="true">
            <MudText Typo="Typo.body2" Color="Color.Secondary">Residence category not set yet.</MudText>
        </AppCard>
    }
}
else if (_editingCategory && CanEdit)
{
    <AppCard Title="Residence category" Outlined="true">
        <MudForm @ref="_categoryForm"
                 @bind-IsValid="_categoryFormValid"
                 Model="_categoryModel"
                 Validation="@(ResidenceCategoryValidator.ToMudValidateValue<SetResidenceCategoryRequest, CategoryFormModel>(MapCategoryRequest))">
            <AppFormSection Title="Why is the person in Belgium?">
                <MudItem xs="12" md="8">
                    <MudSelect T="ResidenceCategory?"
                               @bind-Value="_categoryModel.Category"
                               Label="Residence category"
                               Required="true"
                               ToStringFunc="@FormatCategory">
                        <MudSelectItem T="ResidenceCategory?" Value="ResidenceCategory.EuCitizen">EU citizen</MudSelectItem>
                        <MudSelectItem T="ResidenceCategory?" Value="ResidenceCategory.NonEuWorker">Non-EU worker</MudSelectItem>
                        <MudSelectItem T="ResidenceCategory?" Value="ResidenceCategory.Student">Student</MudSelectItem>
                        <MudSelectItem T="ResidenceCategory?" Value="ResidenceCategory.Refugee">Refugee / temporary protection</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </AppFormSection>

            <AppInfoBox Class="mb-4">
                EU citizens need a passport or national ID on file. Non-EU workers and students must record a valid permit plus identity document. Refugees require a federal protection decision.
            </AppInfoBox>

            <AppSaveCancelBar SaveText="Save changes"
                              CancelText="Cancel"
                              Saving="_savingCategory"
                              Disabled="!CategoryFormDirty"
                              OnSave="SaveCategory"
                              OnCancel="HandleCategoryCancel"/>
        </MudForm>
    </AppCard>
}
else
{
    <AppCard Title="Residence category" Outlined="true">
        <HeaderActions>
            @if (CanEdit)
            {
                <MudButton StartIcon="@Icons.Material.Outlined.Edit"
                           Variant="Variant.Text"
                           OnClick="StartEditingCategory"
                           aria-label="Edit residence category">
                    Edit
                </MudButton>
            }
        </HeaderActions>
        <ChildContent>
            <MudText Typo="Typo.body1">@FormatCategory(_case.ResidenceCategory)</MudText>
            @if (_case.Checklist.LegalResidenceEstablished)
            {
                <MudText Typo="Typo.body2" Color="Color.Success" Class="mt-2">
                    Legal residence established.
                </MudText>
            }
            else if (!string.IsNullOrWhiteSpace(_policyMessage))
            {
                <MudText Typo="Typo.body2" Color="Color.Warning" Class="mt-2">
                    @_policyMessage
                </MudText>
            }
        </ChildContent>
    </AppCard>

    @if (_case.ResidenceCategory == ResidenceCategory.Refugee)
    {
        <AppAlert Severity="Severity.Info" Title="Federal decision required" Class="mt-4">
            Refugee and temporary protection cases require an Immigration Office protection decision before registration can proceed.
        </AppAlert>
    }

    @if (_case.ResidenceCategory == ResidenceCategory.EuCitizen && !_case.Checklist.LegalResidenceEstablished)
    {
        <AppAlert Severity="Severity.Warning" Title="Identity document required" Class="mt-4">
            Attach a passport or national identity card to establish legal residence for EU citizens.
        </AppAlert>
    }

    @if (RequiresPermit(_case.ResidenceCategory.Value))
    {
        @if (_case.ResidencePermit is null)
        {
            @if (CanEdit)
            {
                <AppCard Title="Residence permit" Outlined="true" Class="mt-4">
                    <MudForm @ref="_permitForm"
                             @bind-IsValid="_permitFormValid"
                             Model="_permitModel"
                             Validation="@(ResidencePermitValidator.ToMudValidateValue<RecordResidencePermitRequest, PermitFormModel>(MapPermitRequest))">
                        <AppFormSection Title="Permit details">
                            <MudItem xs="12" md="6">
                                <MudSelect T="ResidencePermitType?"
                                           @bind-Value="_permitModel.PermitType"
                                           Label="Permit type"
                                           Required="true"
                                           ToStringFunc="@FormatPermitType">
                                    @foreach (var permitType in PermitTypesFor(_case.ResidenceCategory.Value))
                                    {
                                        <MudSelectItem T="ResidencePermitType?" Value="@permitType">@FormatPermitType(permitType)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_permitModel.CardNumber" Label="Card number"/>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <AppDateField @bind-Value="_permitModel.ValidFrom"
                                              For="@(() => _permitModel.ValidFrom)"
                                              Label="Valid from"
                                              Required="true"/>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <AppDateField @bind-Value="_permitModel.ValidUntil"
                                              For="@(() => _permitModel.ValidUntil)"
                                              Label="Valid until"
                                              Required="true"/>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_permitModel.IssuingAuthority" Label="Issuing authority"/>
                            </MudItem>
                        </AppFormSection>

                        <AppSaveCancelBar SaveText="Record permit"
                                          CancelText="Clear"
                                          Saving="_savingPermit"
                                          OnSave="SavePermit"
                                          OnCancel="HandlePermitCancel"/>
                    </MudForm>
                </AppCard>
            }
            else
            {
                <AppCard Title="Residence permit" Outlined="true" Class="mt-4">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Residence permit not recorded yet.</MudText>
                </AppCard>
            }
        }
        else if (_editingPermit && CanEdit)
        {
            <AppCard Title="Residence permit" Outlined="true" Class="mt-4">
                <MudForm @ref="_permitForm"
                         @bind-IsValid="_permitFormValid"
                         Model="_permitModel"
                         Validation="@(ResidencePermitValidator.ToMudValidateValue<RecordResidencePermitRequest, PermitFormModel>(MapPermitRequest))">
                    <AppFormSection Title="Permit details">
                        <MudItem xs="12" md="6">
                            <MudSelect T="ResidencePermitType?"
                                       @bind-Value="_permitModel.PermitType"
                                       Label="Permit type"
                                       Required="true"
                                       ToStringFunc="@FormatPermitType">
                                @foreach (var permitType in PermitTypesFor(_case.ResidenceCategory.Value))
                                {
                                    <MudSelectItem T="ResidencePermitType?" Value="@permitType">@FormatPermitType(permitType)</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_permitModel.CardNumber" Label="Card number"/>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <AppDateField @bind-Value="_permitModel.ValidFrom"
                                          For="@(() => _permitModel.ValidFrom)"
                                          Label="Valid from"
                                          Required="true"/>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <AppDateField @bind-Value="_permitModel.ValidUntil"
                                          For="@(() => _permitModel.ValidUntil)"
                                          Label="Valid until"
                                          Required="true"/>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_permitModel.IssuingAuthority" Label="Issuing authority"/>
                        </MudItem>
                    </AppFormSection>

                    <AppSaveCancelBar SaveText="Save changes"
                                      CancelText="Cancel"
                                      Saving="_savingPermit"
                                      Disabled="!PermitFormDirty"
                                      OnSave="SavePermit"
                                      OnCancel="HandlePermitCancel"/>
                </MudForm>
            </AppCard>
        }
        else
        {
            <AppCard Title="Residence permit" Outlined="true" Class="mt-4">
                <HeaderActions>
                    @if (CanEdit)
                    {
                        <MudButton StartIcon="@Icons.Material.Outlined.Edit"
                                   Variant="Variant.Text"
                                   OnClick="StartEditingPermit"
                                   aria-label="Edit residence permit">
                            Edit
                        </MudButton>
                    }
                </HeaderActions>
                <ChildContent>
                    <MudText Typo="Typo.body1">
                        @FormatPermitType(_case.ResidencePermit.PermitType)
                        @if (!string.IsNullOrWhiteSpace(_case.ResidencePermit.CardNumber))
                        {
                            <span> · @_case.ResidencePermit.CardNumber</span>
                        }
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_case.ResidencePermit.ValidFrom.ToString("d") – @_case.ResidencePermit.ValidUntil.ToString("d")
                        @if (!string.IsNullOrWhiteSpace(_case.ResidencePermit.IssuingAuthority))
                        {
                            <span> · @_case.ResidencePermit.IssuingAuthority</span>
                        }
                    </MudText>
                </ChildContent>
            </AppCard>
        }
    }

    @if (_case.ImmigrationDecision is null)
    {
        @if (CanEdit)
        {
            <AppCard Title="@(_case.ResidenceCategory == ResidenceCategory.Refugee ? "Immigration decision (required)" : "Immigration decision (optional)")" Outlined="true" Class="mt-4">
                <ChildContent>
                    <MudForm @ref="_decisionForm"
                             @bind-IsValid="_decisionFormValid"
                             Model="_decisionModel"
                             Validation="@(ImmigrationDecisionValidator.ToMudValidateValue<RecordImmigrationDecisionRequest, DecisionFormModel>(MapDecisionRequest))">
                        <AppFormSection Title="External decision reference">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_decisionModel.ReferenceNumber" Label="Reference number"/>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <AppDateField @bind-Value="_decisionModel.DecisionDate"
                                              For="@(() => _decisionModel.DecisionDate)"
                                              Label="Decision date"/>
                            </MudItem>
                        </AppFormSection>

                        <AppInfoBox Class="mb-4">
                            Stub for federal immigration office decisions — optional for most categories.
                        </AppInfoBox>

                        <AppSaveCancelBar SaveText="Record decision"
                                          CancelText="Clear"
                                          Saving="_savingDecision"
                                          OnSave="SaveDecision"
                                          OnCancel="HandleDecisionCancel"/>
                    </MudForm>
                </ChildContent>
            </AppCard>
        }
        else if (_case.ResidenceCategory == ResidenceCategory.Refugee)
        {
            <AppCard Title="Immigration decision (required)" Outlined="true" Class="mt-4">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Immigration decision not recorded yet.</MudText>
            </AppCard>
        }
    }
    else if (_editingDecision && CanEdit)
    {
        <AppCard Title="@(_case.ResidenceCategory == ResidenceCategory.Refugee ? "Immigration decision (required)" : "Immigration decision (optional)")" Outlined="true" Class="mt-4">
            <ChildContent>
                <MudForm @ref="_decisionForm"
                         @bind-IsValid="_decisionFormValid"
                         Model="_decisionModel"
                         Validation="@(ImmigrationDecisionValidator.ToMudValidateValue<RecordImmigrationDecisionRequest, DecisionFormModel>(MapDecisionRequest))">
                    <AppFormSection Title="External decision reference">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_decisionModel.ReferenceNumber" Label="Reference number"/>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <AppDateField @bind-Value="_decisionModel.DecisionDate"
                                          For="@(() => _decisionModel.DecisionDate)"
                                          Label="Decision date"/>
                        </MudItem>
                    </AppFormSection>

                    <AppInfoBox Class="mb-4">
                        Stub for federal immigration office decisions — optional for most categories.
                    </AppInfoBox>

                    <AppSaveCancelBar SaveText="Save changes"
                                      CancelText="Cancel"
                                      Saving="_savingDecision"
                                      Disabled="!DecisionFormDirty"
                                      OnSave="SaveDecision"
                                      OnCancel="HandleDecisionCancel"/>
                </MudForm>
            </ChildContent>
        </AppCard>
    }
    else
    {
        <AppCard Title="@(_case.ResidenceCategory == ResidenceCategory.Refugee ? "Immigration decision (required)" : "Immigration decision (optional)")" Outlined="true" Class="mt-4">
            <HeaderActions>
                @if (CanEdit)
                {
                    <MudButton StartIcon="@Icons.Material.Outlined.Edit"
                               Variant="Variant.Text"
                               OnClick="StartEditingDecision"
                               aria-label="Edit immigration decision">
                        Edit
                    </MudButton>
                }
            </HeaderActions>
            <ChildContent>
                <MudText Typo="Typo.body1">@_case.ImmigrationDecision!.ReferenceNumber</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Decision date @_case.ImmigrationDecision.DecisionDate.ToString("d")
                </MudText>
            </ChildContent>
        </AppCard>
    }
}

@code {
    [Parameter] [EditorRequired] public RegistrationCaseDetailDto Case { get; set; } = null!;

    [Parameter] [EditorRequired] public Guid CaseId { get; set; }

    [Parameter] public bool CanEdit { get; set; }

    [Parameter] public EventCallback OnUpdated { get; set; }

    private RegistrationCaseDetailDto _case = null!;
    private string? _policyMessage;

    private bool _editingCategory;
    private MudForm _categoryForm = null!;
    private bool _categoryFormValid;
    private bool _savingCategory;
    private readonly CategoryFormModel _categoryModel = new();

    private readonly PermitFormModel _permitModel = new();
    private bool _editingPermit;
    private MudForm _permitForm = null!;
    private bool _permitFormValid;
    private bool _savingPermit;

    private readonly DecisionFormModel _decisionModel = new();
    private bool _editingDecision;
    private MudForm _decisionForm = null!;
    private bool _decisionFormValid;
    private bool _savingDecision;

    protected override void OnParametersSet()
    {
        _case = Case;
        _editingCategory = false;
        _editingPermit = false;
        _editingDecision = false;
    }

    private bool CategoryFormDirty =>
        _categoryModel.Category != _case.ResidenceCategory;

    private bool PermitFormDirty =>
        _case.ResidencePermit is not null &&
        (_permitModel.PermitType != _case.ResidencePermit.PermitType ||
         _permitModel.CardNumber != _case.ResidencePermit.CardNumber ||
         _permitModel.ValidFrom != _case.ResidencePermit.ValidFrom ||
         _permitModel.ValidUntil != _case.ResidencePermit.ValidUntil ||
         _permitModel.IssuingAuthority != _case.ResidencePermit.IssuingAuthority);

    private bool DecisionFormDirty =>
        _case.ImmigrationDecision is not null &&
        (_decisionModel.ReferenceNumber != _case.ImmigrationDecision.ReferenceNumber ||
         _decisionModel.DecisionDate != _case.ImmigrationDecision.DecisionDate);

    private static RecordResidencePermitRequest MapPermitRequest(PermitFormModel model)
    {
        return new RecordResidencePermitRequest(
            model.PermitType ?? default,
            model.ValidFrom ?? default,
            model.ValidUntil ?? default,
            model.CardNumber,
            model.IssuingAuthority);
    }

    private static RecordImmigrationDecisionRequest MapDecisionRequest(DecisionFormModel model)
    {
        return new RecordImmigrationDecisionRequest(
            model.ReferenceNumber ?? string.Empty,
            model.DecisionDate ?? default);
    }

    private static bool RequiresPermit(ResidenceCategory category)
    {
        return category is ResidenceCategory.NonEuWorker or ResidenceCategory.Student;
    }

    private static IEnumerable<ResidencePermitType> PermitTypesFor(ResidenceCategory category)
    {
        return category switch
        {
            ResidenceCategory.NonEuWorker =>
            [
                ResidencePermitType.ACard,
                ResidencePermitType.BCard
            ],
            ResidenceCategory.Student =>
            [
                ResidencePermitType.Annex15,
                ResidencePermitType.BCard
            ],
            _ => []
        };
    }

    private static string FormatCategory(ResidenceCategory? category)
    {
        return category switch
        {
            ResidenceCategory.EuCitizen => "EU citizen",
            ResidenceCategory.NonEuWorker => "Non-EU worker",
            ResidenceCategory.Student => "Student",
            ResidenceCategory.Refugee => "Refugee / temporary protection",
            _ => "Select category"
        };
    }

    private static string FormatPermitType(ResidencePermitType? permitType)
    {
        return permitType switch
        {
            ResidencePermitType.ACard => "A card",
            ResidencePermitType.BCard => "B card",
            ResidencePermitType.CCard => "C card",
            ResidencePermitType.Annex15 => "Annex 15",
            ResidencePermitType.EuRegistrationCertificate => "EU registration certificate",
            _ => "Select permit type"
        };
    }

    private void StartEditingCategory()
    {
        _categoryModel.Category = _case.ResidenceCategory;
        _editingCategory = true;
    }

    private async Task CancelEditingCategory()
    {
        if (CategoryFormDirty)
        {
            var confirmed = await DialogService.ConfirmAsync(
                "Discard changes?",
                "You have unsaved category changes.",
                "Discard");

            if (!confirmed)
            {
                return;
            }
        }

        _editingCategory = false;
        _categoryModel.Category = null;
    }

    private void ClearCategoryForm()
    {
        _categoryModel.Category = null;
    }

    private async Task HandleCategoryCancel()
    {
        if (_editingCategory)
        {
            await CancelEditingCategory();
        }
        else
        {
            ClearCategoryForm();
        }
    }

    private async Task SaveCategory()
    {
        await _categoryForm.ValidateAsync();
        if (!_categoryFormValid || _categoryModel.Category is null)
        {
            return;
        }

        _savingCategory = true;
        try
        {
            var response = await RegistrationApi.SetResidenceCategoryAsync(
                CaseId,
                MapCategoryRequest(_categoryModel),
                CancellationToken.None);

            _policyMessage = response.PolicyMessage;
            _editingCategory = false;
            Snackbar.Add(
                response.LegalResidenceEstablished
                    ? "Residence category saved — legal residence established."
                    : "Residence category saved.",
                response.LegalResidenceEstablished ? Severity.Success : Severity.Warning);

            await OnUpdated.InvokeAsync();
        }
        catch (ValidationException ex)
        {
            Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error);
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingCategory = false;
        }
    }

    private void StartEditingPermit()
    {
        if (_case.ResidencePermit is null)
        {
            return;
        }

        _permitModel.PermitType = _case.ResidencePermit.PermitType;
        _permitModel.CardNumber = _case.ResidencePermit.CardNumber;
        _permitModel.ValidFrom = _case.ResidencePermit.ValidFrom;
        _permitModel.ValidUntil = _case.ResidencePermit.ValidUntil;
        _permitModel.IssuingAuthority = _case.ResidencePermit.IssuingAuthority;
        _editingPermit = true;
    }

    private async Task CancelEditingPermit()
    {
        if (PermitFormDirty)
        {
            var confirmed = await DialogService.ConfirmAsync(
                "Discard changes?",
                "You have unsaved permit changes.",
                "Discard");

            if (!confirmed)
            {
                return;
            }
        }

        _editingPermit = false;
    }

    private void ClearPermitForm()
    {
        _permitModel.PermitType = null;
        _permitModel.CardNumber = null;
        _permitModel.ValidFrom = null;
        _permitModel.ValidUntil = null;
        _permitModel.IssuingAuthority = null;
    }

    private async Task HandlePermitCancel()
    {
        if (_editingPermit)
        {
            await CancelEditingPermit();
        }
        else
        {
            ClearPermitForm();
        }
    }

    private async Task SavePermit()
    {
        await _permitForm.ValidateAsync();
        if (!_permitFormValid || _permitModel.PermitType is null || _permitModel.ValidFrom is null || _permitModel.ValidUntil is null)
        {
            return;
        }

        _savingPermit = true;
        try
        {
            var response = await RegistrationApi.RecordResidencePermitAsync(
                CaseId,
                MapPermitRequest(_permitModel),
                CancellationToken.None);

            _policyMessage = response.PolicyMessage;
            _editingPermit = false;
            Snackbar.Add(
                response.LegalResidenceEstablished
                    ? "Residence permit saved — legal residence established."
                    : "Residence permit saved.",
                response.LegalResidenceEstablished ? Severity.Success : Severity.Warning);

            await OnUpdated.InvokeAsync();
        }
        catch (ValidationException ex)
        {
            Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error);
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingPermit = false;
        }
    }

    private void StartEditingDecision()
    {
        if (_case.ImmigrationDecision is null)
        {
            return;
        }

        _decisionModel.ReferenceNumber = _case.ImmigrationDecision.ReferenceNumber;
        _decisionModel.DecisionDate = _case.ImmigrationDecision.DecisionDate;
        _editingDecision = true;
    }

    private async Task CancelEditingDecision()
    {
        if (DecisionFormDirty)
        {
            var confirmed = await DialogService.ConfirmAsync(
                "Discard changes?",
                "You have unsaved decision changes.",
                "Discard");

            if (!confirmed)
            {
                return;
            }
        }

        _editingDecision = false;
    }

    private void ClearDecisionForm()
    {
        _decisionModel.ReferenceNumber = null;
        _decisionModel.DecisionDate = null;
    }

    private async Task HandleDecisionCancel()
    {
        if (_editingDecision)
        {
            await CancelEditingDecision();
        }
        else
        {
            ClearDecisionForm();
        }
    }

    private async Task SaveDecision()
    {
        await _decisionForm.ValidateAsync();
        if (!_decisionFormValid || string.IsNullOrWhiteSpace(_decisionModel.ReferenceNumber) || _decisionModel.DecisionDate is null)
        {
            return;
        }

        _savingDecision = true;
        try
        {
            var response = await RegistrationApi.RecordImmigrationDecisionAsync(
                CaseId,
                MapDecisionRequest(_decisionModel),
                CancellationToken.None);

            _policyMessage = response.PolicyMessage;
            _editingDecision = false;
            Snackbar.Add("Immigration decision saved.", Severity.Success);
            await OnUpdated.InvokeAsync();
        }
        catch (ValidationException ex)
        {
            Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error);
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingDecision = false;
        }
    }

    private SetResidenceCategoryRequest MapCategoryRequest(CategoryFormModel model)
    {
        return new SetResidenceCategoryRequest(model.Category!.Value);
    }

    private sealed class CategoryFormModel
    {
        public ResidenceCategory? Category { get; set; }
    }

    private sealed class PermitFormModel
    {
        public ResidencePermitType? PermitType { get; set; }
        public string? CardNumber { get; set; }
        public DateOnly? ValidFrom { get; set; }
        public DateOnly? ValidUntil { get; set; }
        public string? IssuingAuthority { get; set; }
    }

    private sealed class DecisionFormModel
    {
        public string? ReferenceNumber { get; set; }
