@using SchaerbeekMunicipality.Domain.Registration
@using SchaerbeekMunicipality.Application.Features.Registration
@using SchaerbeekMunicipality.Application.Features.Registration.OpenRegistrationCase
@using SchaerbeekMunicipality.Application.Features.BirthDeclaration.OpenBirthDeclarationCase

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h4">Open registration case</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValid">
            <MudSelect T="VisitReason" @bind-Value="_visitReason" Label="Visit reason" Required="true" Class="mb-3">
                @foreach (var reason in Enum.GetValues<VisitReason>())
                {
                    <MudSelectItem Value="reason">@VisitReasonLabels.For(reason)</MudSelectItem>
                }
            </MudSelect>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Assigned officer: @OfficerName
            </MudText>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Style="min-height: 48px;"
                   OnClick="Submit"
                   Disabled="_submitting"
                   aria-busy="@_submitting">
            Open case
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string OfficerName { get; set; } = string.Empty;

    [Parameter]
    public OpenRegistrationCaseHandler Handler { get; set; } = null!;

    [Parameter]
    public OpenBirthDeclarationCaseHandler BirthHandler { get; set; } = null!;

    private MudForm _form = null!;
    private bool _formValid;
    private bool _submitting;
    private VisitReason _visitReason = VisitReason.FirstRegistration;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_formValid)
        {
            return;
        }

        _submitting = true;
        try
        {
            if (_visitReason == VisitReason.BirthDeclaration)
            {
                var birthResult = await BirthHandler.Handle(CancellationToken.None);
                MudDialog.Close(DialogResult.Ok(new NewCaseDialogResult(birthResult.CaseId, true)));
            }
            else if (_visitReason == VisitReason.ChangeOfAddress)
            {
                MudDialog.Close(DialogResult.Ok(new NewCaseDialogResult(Guid.Empty, false, true)));
            }
            else
            {
                var result = await Handler.Handle(
                    new OpenRegistrationCaseRequest(_visitReason, null),
                    CancellationToken.None);

                MudDialog.Close(DialogResult.Ok(new NewCaseDialogResult(result.CaseId, false)));
            }
        }
        finally
        {
            _submitting = false;
        }
    }
}
