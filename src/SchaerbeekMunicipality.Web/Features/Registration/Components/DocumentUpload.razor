@using Microsoft.AspNetCore.Components.Forms
@using SchaerbeekMunicipality.Domain.Documents
@using SchaerbeekMunicipality.Domain.Registration
@using SchaerbeekMunicipality.Web.Features.Registration.AttachDocument

<AppCard Title="Attach document" Outlined="true">
    <MudSelect T="DocumentType" @bind-Value="_documentType" Label="Document type" Class="mb-3">
        <MudSelectItem Value="DocumentType.Passport">Passport</MudSelectItem>
        <MudSelectItem Value="DocumentType.NationalIdCard">National ID card</MudSelectItem>
        <MudSelectItem Value="DocumentType.BirthCertificate">Birth certificate</MudSelectItem>
        <MudSelectItem Value="DocumentType.ResidencePermit">Residence permit</MudSelectItem>
        <MudSelectItem Value="DocumentType.Other">Other</MudSelectItem>
    </MudSelect>

    <MudFileUpload T="IBrowserFile" Accept=".pdf,.jpg,.jpeg,.png" FilesChanged="OnFileSelected">
        <ActivatorContent>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Upload">
                Choose file
            </MudButton>
        </ActivatorContent>
    </MudFileUpload>

    @if (_selectedFile is not null)
    {
        <MudText Typo="Typo.body2" Class="mt-2">Selected: @_selectedFile.Name</MudText>
    }

    <MudButton Class="mt-3"
               Variant="Variant.Filled"
               Color="Color.Secondary"
               Disabled="_uploading || _selectedFile is null"
               OnClick="Upload">
        Upload
    </MudButton>
</AppCard>

@code {
    [Parameter, EditorRequired]
    public Guid CaseId { get; set; }

    [Parameter, EditorRequired]
    public AttachDocumentHandler Handler { get; set; } = null!;

    [Parameter]
    public EventCallback OnUploaded { get; set; }

    [Inject]
    private ISnackbar Snackbar { get; set; } = null!;

    private DocumentType _documentType = DocumentType.Passport;
    private IBrowserFile? _selectedFile;
    private bool _uploading;

    private void OnFileSelected(IBrowserFile file) => _selectedFile = file;

    private async Task Upload()
    {
        if (_selectedFile is null)
        {
            return;
        }

        _uploading = true;
        try
        {
            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            await Handler.Handle(
                new RegistrationCaseId(CaseId),
                _documentType,
                _selectedFile.Name,
                stream,
                CancellationToken.None);

            Snackbar.Add("Document uploaded.", Severity.Success);
            _selectedFile = null;
            await OnUploaded.InvokeAsync();
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _uploading = false;
        }
    }
}
