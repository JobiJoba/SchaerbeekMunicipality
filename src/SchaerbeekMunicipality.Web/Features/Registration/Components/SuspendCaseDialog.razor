@using SchaerbeekMunicipality.Domain.Registration
@using SchaerbeekMunicipality.Application.Features.Registration.SuspendCase

<ReasonNotesDialog TReason="SuspensionReason"
                   TRequest="SuspendCaseRequest"
                   ReasonLabel="Suspension reason"
                   ConfirmText="Suspend case"
                   ConfirmColor="Color.Warning"
                   FormatReason="FormatReason"
                   CreateRequest="CreateRequest"/>

@code {

    private static SuspendCaseRequest CreateRequest(SuspensionReason reason, string? notes) =>
        new(reason, notes);

    private static string FormatReason(SuspensionReason reason) =>
        reason switch
        {
            SuspensionReason.MissingDocuments => "Missing documents",
            SuspensionReason.AwaitingFederalDecision => "Awaiting federal decision",
            SuspensionReason.MarriageRecognitionPending => "Marriage recognition pending",
            SuspensionReason.InvestigationRequired => "Investigation required",
            _ => "Other",
        };

}
