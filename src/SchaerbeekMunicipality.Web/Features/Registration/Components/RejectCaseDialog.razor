@using SchaerbeekMunicipality.Application.Features.Registration.RejectCase
<ReasonNotesDialog TReason="RejectionReason"
                   TRequest="RejectCaseRequest"
                   ReasonLabel="Rejection reason"
                   ConfirmText="Close case"
                   ConfirmColor="Color.Error"
                   FormatReason="FormatReason"
                   CreateRequest="CreateRequest"
                   InitialReason="@InitialReason"
                   InitialNotes="@InitialNotes"/>

@code {
    [Parameter] public RejectionReason? InitialReason { get; set; }

    [Parameter] public string? InitialNotes { get; set; }

    private static RejectCaseRequest CreateRequest(RejectionReason reason, string? notes)
    {
        return new RejectCaseRequest(reason, notes);
    }

    private static string FormatReason(RejectionReason reason)
    {
        return reason switch
        {
            RejectionReason.InsufficientIdentityEvidence => "Insufficient identity evidence",
            RejectionReason.NoLegalResidenceBasis => "No legal residence basis",
            RejectionReason.AddressNotGenuine => "Address not genuine",
            RejectionReason.DuplicateIdentity => "Duplicate identity",
            RejectionReason.IllegalStay => "Illegal stay",
            RejectionReason.OpenedInError => "Opened in error (wrong person)",
            _ => "Other"
        };
    }

}