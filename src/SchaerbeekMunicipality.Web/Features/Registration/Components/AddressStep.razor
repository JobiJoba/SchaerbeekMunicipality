@using FluentValidation
@using SchaerbeekMunicipality.Application.Features.Registration.DeclareAddress
@using SchaerbeekMunicipality.Application.Features.Registration.GetRegistrationCase
@using SchaerbeekMunicipality.Application.Features.Registration.RecordHousingSituation
@using SchaerbeekMunicipality.Application.Features.Registration.SearchReferenceData
@using SchaerbeekMunicipality.Domain.Address
@using SchaerbeekMunicipality.Domain.ReferenceData
@using SchaerbeekMunicipality.Web.Api.Registration
@using Severity = MudBlazor.Severity
@inject IRegistrationApi RegistrationApi
@inject IValidator<DeclareAddressRequest> DeclareAddressValidator
@inject IValidator<RecordHousingSituationRequest> HousingSituationValidator
@inject IAppDialogService DialogService
@inject ISnackbar Snackbar

@if (!_case.Checklist.IdentityEstablished)
{
    <AppInfoBox>
        Record identity before declaring an address.
    </AppInfoBox>
}
else if (_case.DeclaredAddress is null)
{
    @if (CanEdit)
    {
        <AppCard Title="Declared address" Outlined="true">
            <MudSwitch T="bool"
                       @bind-Value="_useReferenceAddress"
                       Label="No fixed abode — use reference address"
                       Color="Color.Primary"
                       Class="mb-3"/>

            @if (_useReferenceAddress)
            {
                <AppAlert Severity="Severity.Info" Title="Reference address" Class="mb-3">
                    Persons without a fixed domicile are registered at the municipality-hosted reference address.
                    Police verification still applies to this site.
                </AppAlert>
                <MudText Typo="Typo.body1" Class="mb-3">
                    @SchaerbeekCommune.ReferenceStreet @SchaerbeekCommune.ReferenceHouseNumber,
                    @SchaerbeekCommune.PostalCode @SchaerbeekCommune.Name
                </MudText>
                <AppSaveCancelBar SaveText="Declare reference address"
                                  CancelText="Clear"
                                  Saving="_savingAddress"
                                  OnSave="SaveReferenceAddress"
                                  OnCancel="HandleAddressCancel"/>
            }
            else
            {
                <MudForm @ref="_addressForm"
                         @bind-IsValid="_addressFormValid"
                         Model="_addressModel"
                         Validation="@(DeclareAddressValidator.ToMudValidateValue<DeclareAddressRequest, AddressFormModel>(MapAddressRequest))">
                    <BelgianAddressFields @bind-SelectedStreet="_selectedStreet"
                                          @bind-HouseNumber="_addressModel.HouseNumber"
                                          @bind-Box="_addressModel.Box"
                                          SearchStreets="SearchStreets"
                                          ShowHelpText="true"/>

                    <AppSaveCancelBar SaveText="Declare address"
                                      CancelText="Clear"
                                      Saving="_savingAddress"
                                      OnSave="SaveAddress"
                                      OnCancel="HandleAddressCancel"/>
                </MudForm>
            }
        </AppCard>
    }
    else
    {
        <AppCard Title="Declared address" Outlined="true">
            <MudText Typo="Typo.body2" Color="Color.Secondary">Address not declared yet.</MudText>
        </AppCard>
    }
}
else if (_editingAddress && CanEdit)
{
    <AppCard Title="Declared address" Outlined="true">
        <MudSwitch T="bool"
                   @bind-Value="_useReferenceAddress"
                   Label="No fixed abode — use reference address"
                   Color="Color.Primary"
                   Class="mb-3"/>

        @if (_useReferenceAddress)
        {
            <AppAlert Severity="Severity.Info" Title="Reference address" Class="mb-3">
                Persons without a fixed domicile are registered at the municipality-hosted reference address.
                Police verification still applies to this site.
            </AppAlert>
            <MudText Typo="Typo.body1" Class="mb-3">
                @SchaerbeekCommune.ReferenceStreet @SchaerbeekCommune.ReferenceHouseNumber,
                @SchaerbeekCommune.PostalCode @SchaerbeekCommune.Name
            </MudText>
            <AppSaveCancelBar SaveText="Save reference address"
                              CancelText="Cancel"
                              Saving="_savingAddress"
                              OnSave="SaveReferenceAddress"
                              OnCancel="HandleAddressCancel"/>
        }
        else
        {
            <MudForm @ref="_addressForm"
                     @bind-IsValid="_addressFormValid"
                     Model="_addressModel"
                     Validation="@(DeclareAddressValidator.ToMudValidateValue<DeclareAddressRequest, AddressFormModel>(MapAddressRequest))">
                <BelgianAddressFields @bind-SelectedStreet="_selectedStreet"
                                      @bind-HouseNumber="_addressModel.HouseNumber"
                                      @bind-Box="_addressModel.Box"
                                      SearchStreets="SearchStreets"
                                      ShowHelpText="true"/>

                <AppSaveCancelBar SaveText="Save changes"
                                  CancelText="Cancel"
                                  Saving="_savingAddress"
                                  Disabled="!AddressFormDirty"
                                  OnSave="SaveAddress"
                                  OnCancel="HandleAddressCancel"/>
            </MudForm>
        }
    </AppCard>
}
else
{
    <AppCard Title="Declared address" Outlined="true">
        <HeaderActions>
            @if (CanEdit)
            {
                <MudButton StartIcon="@Icons.Material.Outlined.Edit"
                           Variant="Variant.Text"
                           OnClick="StartEditingAddress"
                           aria-label="Edit address">
                    Edit
                </MudButton>
            }
        </HeaderActions>
        <ChildContent>
            @if (_case.AddressDeclarationType == AddressDeclarationType.ReferenceAddress)
            {
                <AppAlert Severity="Severity.Info" Title="Reference address" Class="mb-2">
                    No fixed abode — municipality-hosted reference address.
                </AppAlert>
            }
            <MudText Typo="Typo.body1">@AddressFormatting.FormatBelgianAddress(_case.DeclaredAddress)</MudText>
        </ChildContent>
    </AppCard>
}

@if (_case.DeclaredAddress is not null)
{
    @if (_case.HousingSituation is null)
    {
        @if (CanEdit)
        {
            <AppCard Title="Housing situation" Outlined="true" Class="mt-4">
                <MudForm @ref="_housingForm"
                         @bind-IsValid="_housingFormValid"
                         Model="_housingModel"
                         Validation="@(HousingSituationValidator.ToMudValidateValue<RecordHousingSituationRequest, HousingFormModel>(MapHousingRequest))">
                    <AppFormSection Title="How does the person occupy this address?">
                        <MudItem xs="12" md="6">
                            <MudSelect T="HousingSituation?"
                                       @bind-Value="_housingModel.Situation"
                                       Label="Housing situation"
                                       Required="true"
                                       ToStringFunc="@FormatHousingSituation">
                                <MudSelectItem T="HousingSituation?" Value="HousingSituation.Owner">Owner</MudSelectItem>
                                <MudSelectItem T="HousingSituation?" Value="HousingSituation.Tenant">Tenant</MudSelectItem>
                                <MudSelectItem T="HousingSituation?" Value="HousingSituation.Lodging">Lodging</MudSelectItem>
                                <MudSelectItem T="HousingSituation?" Value="HousingSituation.StudentHousing">Student housing</MudSelectItem>
                                <MudSelectItem T="HousingSituation?" Value="HousingSituation.Shelter">Shelter</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </AppFormSection>

                    <AppSaveCancelBar SaveText="Record situation"
                                      CancelText="Clear"
                                      Saving="_savingHousing"
                                      OnSave="SaveHousing"
                                      OnCancel="HandleHousingCancel"/>
                </MudForm>
            </AppCard>
        }
        else
        {
            <AppCard Title="Housing situation" Outlined="true" Class="mt-4">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Housing situation not recorded yet.</MudText>
            </AppCard>
        }
    }
    else if (_editingHousing && CanEdit)
    {
        <AppCard Title="Housing situation" Outlined="true" Class="mt-4">
            <MudForm @ref="_housingForm"
                     @bind-IsValid="_housingFormValid"
                     Model="_housingModel"
                     Validation="@(HousingSituationValidator.ToMudValidateValue<RecordHousingSituationRequest, HousingFormModel>(MapHousingRequest))">
                <AppFormSection Title="How does the person occupy this address?">
                    <MudItem xs="12" md="6">
                        <MudSelect T="HousingSituation?"
                                   @bind-Value="_housingModel.Situation"
                                   Label="Housing situation"
                                   Required="true"
                                   ToStringFunc="@FormatHousingSituation">
                            <MudSelectItem T="HousingSituation?" Value="HousingSituation.Owner">Owner</MudSelectItem>
                            <MudSelectItem T="HousingSituation?" Value="HousingSituation.Tenant">Tenant</MudSelectItem>
                            <MudSelectItem T="HousingSituation?" Value="HousingSituation.Lodging">Lodging</MudSelectItem>
                            <MudSelectItem T="HousingSituation?" Value="HousingSituation.StudentHousing">Student housing</MudSelectItem>
                            <MudSelectItem T="HousingSituation?" Value="HousingSituation.Shelter">Shelter</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </AppFormSection>

                <AppSaveCancelBar SaveText="Save changes"
                                  CancelText="Cancel"
                                  Saving="_savingHousing"
                                  Disabled="!HousingFormDirty"
                                  OnSave="SaveHousing"
                                  OnCancel="HandleHousingCancel"/>
            </MudForm>
        </AppCard>
    }
    else
    {
        <AppCard Title="Housing situation" Outlined="true" Class="mt-4">
            <HeaderActions>
                @if (CanEdit)
                {
                    <MudButton StartIcon="@Icons.Material.Outlined.Edit"
                               Variant="Variant.Text"
                               OnClick="StartEditingHousing"
                               aria-label="Edit housing situation">
                        Edit
                    </MudButton>
                }
            </HeaderActions>
            <ChildContent>
                <MudText Typo="Typo.body1">@FormatHousingSituation(_case.HousingSituation)</MudText>
            </ChildContent>
        </AppCard>
    }
}

@code {
    [Parameter] [EditorRequired] public RegistrationCaseDetailDto Case { get; set; } = null!;

    [Parameter] [EditorRequired] public Guid CaseId { get; set; }

    [Parameter] public bool CanEdit { get; set; }

    [Parameter] public EventCallback OnUpdated { get; set; }

    private RegistrationCaseDetailDto _case = null!;
    private bool _editingAddress;
    private bool _editingHousing;
    private MudForm _addressForm = null!;
    private bool _addressFormValid;
    private bool _savingAddress;
    private MudForm _housingForm = null!;
    private bool _housingFormValid;
    private bool _savingHousing;

    private readonly AddressFormModel _addressModel = new();
    private readonly HousingFormModel _housingModel = new();

    private StreetDto? _selectedStreet;
    private bool _useReferenceAddress;

    private static readonly MunicipalityDto Schaerbeek = new(
        SchaerbeekCommune.PostalCode,
        SchaerbeekCommune.Name);

    protected override void OnParametersSet()
    {
        _case = Case;
        _editingAddress = false;
        _editingHousing = false;
        _useReferenceAddress = _case.AddressDeclarationType == AddressDeclarationType.ReferenceAddress;
    }

    private bool AddressFormDirty =>
        _case.DeclaredAddress is not null &&
        (_selectedStreet?.Name != _case.DeclaredAddress.Street ||
         _addressModel.HouseNumber != _case.DeclaredAddress.HouseNumber ||
         _addressModel.Box != _case.DeclaredAddress.Box);

    private bool HousingFormDirty => _housingModel.Situation != _case.HousingSituation;

    private static string FormatHousingSituation(HousingSituation? situation)
    {
        return situation switch
        {
            HousingSituation.Owner => "Owner",
            HousingSituation.Tenant => "Tenant",
            HousingSituation.Lodging => "Lodging",
            HousingSituation.StudentHousing => "Student housing",
            HousingSituation.Shelter => "Shelter",
            _ => "Select situation"
        };
    }

    private async Task<IEnumerable<StreetDto>> SearchStreets(string? value, CancellationToken token)
    {
        return await RegistrationApi.SearchStreetsAsync(SchaerbeekCommune.PostalCode, value ?? string.Empty, token);
    }

    private void StartEditingAddress()
    {
        if (_case.DeclaredAddress is null)
        {
            return;
        }

        _useReferenceAddress = _case.AddressDeclarationType == AddressDeclarationType.ReferenceAddress;
        _selectedStreet = new StreetDto(0, _case.DeclaredAddress.PostalCode, _case.DeclaredAddress.Street);
        _addressModel.HouseNumber = _case.DeclaredAddress.HouseNumber;
        _addressModel.Box = _case.DeclaredAddress.Box;
        _addressModel.Street = _case.DeclaredAddress.Street;
        _editingAddress = true;
    }

    private async Task CancelEditingAddress()
    {
        if (AddressFormDirty)
        {
            var confirmed = await DialogService.ConfirmAsync(
                "Discard changes?",
                "You have unsaved address changes.",
                "Discard");

            if (!confirmed)
            {
                return;
            }
        }

        _editingAddress = false;
    }

    private void ClearAddressForm()
    {
        _selectedStreet = null;
        _addressModel.Street = string.Empty;
        _addressModel.HouseNumber = string.Empty;
        _addressModel.Box = null;
        _useReferenceAddress = false;
    }

    private async Task HandleAddressCancel()
    {
        if (_editingAddress)
        {
            await CancelEditingAddress();
        }
        else
        {
            ClearAddressForm();
        }
    }

    private async Task SaveAddress()
    {
        SyncAddressModel();
        await _addressForm.ValidateAsync();
        if (!_addressFormValid || _selectedStreet is null)
        {
            return;
        }

        _savingAddress = true;
        try
        {
            await RegistrationApi.DeclareAddressAsync(
                CaseId,
                MapAddressRequest(_addressModel),
                CancellationToken.None);

            _editingAddress = false;
            Snackbar.Add("Address saved.", Severity.Success);
            await OnUpdated.InvokeAsync();
        }
        catch (ValidationException ex)
        {
            Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error);
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingAddress = false;
        }
    }

    private async Task SaveReferenceAddress()
    {
        _savingAddress = true;
        try
        {
            await RegistrationApi.DeclareReferenceAddressAsync(CaseId, CancellationToken.None);
            _editingAddress = false;
            Snackbar.Add("Reference address declared.", Severity.Success);
            await OnUpdated.InvokeAsync();
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingAddress = false;
        }
    }

    private void StartEditingHousing()
    {
        _housingModel.Situation = _case.HousingSituation;
        _editingHousing = true;
    }

    private async Task CancelEditingHousing()
    {
        if (HousingFormDirty)
        {
            var confirmed = await DialogService.ConfirmAsync(
                "Discard changes?",
                "You have unsaved housing changes.",
                "Discard");

            if (!confirmed)
            {
                return;
            }
        }

        _editingHousing = false;
    }

    private void ClearHousingForm()
    {
        _housingModel.Situation = null;
    }

    private async Task HandleHousingCancel()
    {
        if (_editingHousing)
        {
            await CancelEditingHousing();
        }
        else
        {
            ClearHousingForm();
        }
    }

    private async Task SaveHousing()
    {
        await _housingForm.ValidateAsync();
        if (!_housingFormValid || _housingModel.Situation is null)
        {
            return;
        }

        _savingHousing = true;
        try
        {
            await RegistrationApi.RecordHousingSituationAsync(
                CaseId,
                MapHousingRequest(_housingModel),
                CancellationToken.None);

            _editingHousing = false;
            Snackbar.Add("Housing situation saved.", Severity.Success);
            await OnUpdated.InvokeAsync();
        }
        catch (ValidationException ex)
        {
            Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error);
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingHousing = false;
        }
    }

    private void SyncAddressModel()
    {
        _addressModel.Street = _selectedStreet?.Name ?? string.Empty;
    }

    private DeclareAddressRequest MapAddressRequest(AddressFormModel model)
    {
        return new DeclareAddressRequest(
            model.Street,
            model.HouseNumber,
            model.Box,
            Schaerbeek.PostalCode,
            Schaerbeek.Name);
    }

    private RecordHousingSituationRequest MapHousingRequest(HousingFormModel model)
    {
        return new RecordHousingSituationRequest(model.Situation!.Value);
    }

    private sealed class AddressFormModel
    {
        public string Street { get; set; } = string.Empty;
        public string HouseNumber { get; set; } = string.Empty;
        public string? Box { get; set; }
    }

    private sealed class HousingFormModel
    {
        public HousingSituation? Situation { get; set; }
    }

}