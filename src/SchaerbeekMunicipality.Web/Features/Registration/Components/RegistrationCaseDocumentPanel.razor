@using SchaerbeekMunicipality.Domain.Documents
@using SchaerbeekMunicipality.Application.Features.Registration.AttachDocument
@using SchaerbeekMunicipality.Application.Features.Registration.GetRegistrationCase
@inject NavigationManager Navigation

<CaseDocumentPanel Documents="@MapDocuments()"
                   CanEdit="CanEdit"
                   GetDocumentUrl="GetDocumentUrl"
                   OnRemoveDocument="OnRemoveDocument"
                   EmptyTitle="No documents attached"
                   EmptyDescription="Upload a passport, permit, or other supporting document.">
    <UploadContent>
        <DocumentUpload CaseId="CaseId"
                        Handler="AttachHandler"
                        OnUploaded="OnUploaded" />
    </UploadContent>
</CaseDocumentPanel>

@code {
    [Parameter, EditorRequired]
    public Guid CaseId { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyList<DocumentDto> Documents { get; set; } = [];

    [Parameter, EditorRequired]
    public AttachDocumentHandler AttachHandler { get; set; } = null!;

    [Parameter]
    public bool CanEdit { get; set; }

    [Parameter]
    public EventCallback<Guid> OnRemoveDocument { get; set; }

    [Parameter]
    public EventCallback OnUploaded { get; set; }

    private IReadOnlyList<CaseDocumentItem> MapDocuments() =>
        Documents.Select(d => new CaseDocumentItem(
            d.Id,
            d.FileName,
            d.UploadedAt,
            d.DocumentType.ToString())).ToList();

    private string GetDocumentUrl(Guid documentId) =>
        Navigation.ToAbsoluteUri($"/api/registration/cases/{CaseId}/documents/{documentId}").ToString();
}
