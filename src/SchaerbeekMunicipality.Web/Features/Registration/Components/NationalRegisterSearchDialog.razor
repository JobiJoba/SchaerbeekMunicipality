@using SchaerbeekMunicipality.Domain.NationalRegister
@using SchaerbeekMunicipality.Domain.Registration
@using SchaerbeekMunicipality.Application.Features.Registration.LinkExistingPerson
@using SchaerbeekMunicipality.Application.Features.Registration.SearchNationalRegister

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h4">Search National Register</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Search for an existing BIS or National Register record. Enter any combination of name and date of birth — all fields are optional.
        </MudText>

        <NationalRegisterSearchForm InitialGivenName="InitialGivenName"
                                    InitialFamilyName="InitialFamilyName"
                                    InitialBirthDate="InitialBirthDate"
                                    RequireSearchCriterion="true"
                                    ShowMatchScore="true"
                                    ShowFormattedNumbers="true"
                                    NoMatchesMessage="No matching records found. You can create a new person file on the case."
                                    SearchAsync="SearchAsync">
            <RowActions Context="match">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Disabled="_linking"
                           OnClick="@(() => LinkMatch(match))">
                    Link
                </MudButton>
            </RowActions>
        </NationalRegisterSearchForm>

        @if (!string.IsNullOrWhiteSpace(_linkError))
        {
            <AppAlert Severity="Severity.Error" Title="Error" Class="mt-4">@_linkError</AppAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public Guid CaseId { get; set; }

    [Parameter]
    public SearchNationalRegisterHandler SearchHandler { get; set; } = null!;

    [Parameter]
    public LinkExistingPersonHandler LinkHandler { get; set; } = null!;

    [Parameter]
    public string? InitialGivenName { get; set; }

    [Parameter]
    public string? InitialFamilyName { get; set; }

    [Parameter]
    public DateOnly? InitialBirthDate { get; set; }

    private bool _linking;
    private string? _linkError;

    private async Task<IReadOnlyList<NationalRegisterSearchMatch>> SearchAsync(NrSearchFormCriteria criteria)
    {
        var response = await SearchHandler.Handle(
            new SearchNationalRegisterRequest(criteria.GivenName, criteria.FamilyName, criteria.BirthDate),
            CancellationToken.None);

        return response.Matches.Select(Map).ToList();
    }

    private async Task LinkMatch(NationalRegisterSearchMatch match)
    {
        _linking = true;
        _linkError = null;

        try
        {
            await LinkHandler.Handle(
                new RegistrationCaseId(CaseId),
                new LinkExistingPersonRequest(match.RegisterPersonId),
                CancellationToken.None);

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (FluentValidation.ValidationException ex)
        {
            _linkError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            _linkError = ex.Message;
        }
        catch (NationalRegisterConflictException ex)
        {
            _linkError = ex.Message;
        }
        catch (KeyNotFoundException ex)
        {
            _linkError = ex.Message;
        }
        finally
        {
            _linking = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private static NationalRegisterSearchMatch Map(NationalRegisterMatchDto match) =>
        new(
            match.RegisterPersonId,
            match.GivenName,
            match.FamilyName,
            match.BirthDate,
            match.BisNumber,
            match.NationalRegisterNumber,
            match.MatchScore,
            match.MatchReason);
}
