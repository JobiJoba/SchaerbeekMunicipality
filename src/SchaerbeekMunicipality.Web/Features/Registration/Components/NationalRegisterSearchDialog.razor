@using FluentValidation
@using SchaerbeekMunicipality.Application.Features.Registration.LinkExistingPerson
@using SchaerbeekMunicipality.Application.Features.Registration.SearchNationalRegister
@using SchaerbeekMunicipality.Domain.NationalRegister
@using SchaerbeekMunicipality.Web.Api.Registration
@using Severity = MudBlazor.Severity
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h4">Search National Register</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Search for an existing BIS or National Register record. Enter any combination of name and date of birth — all fields are optional.
        </MudText>

        <NationalRegisterSearchForm ShowMatchScore="true"
                                    ShowFormattedNumbers="true"
                                    NoMatchesMessage="No matching records found. You can create a new person file on the case."
                                    SearchAsync="SearchAsync">
            <RowActions Context="match">
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">
                    @if (match.CanOpenPersonFile)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Already linked</MudText>
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   Href="@($"/persons/{match.PersonId}")">
                            View file
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Disabled="_linking"
                                   OnClick="@(() => LinkMatch(match))">
                            Link
                        </MudButton>
                    }
                </MudStack>
            </RowActions>
        </NationalRegisterSearchForm>

        @if (!string.IsNullOrWhiteSpace(_linkError))
        {
            <AppAlert Severity="Severity.Error" Title="Error" Class="mt-4">@_linkError</AppAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Guid CaseId { get; set; }

    [Inject] private IRegistrationApi RegistrationApi { get; set; } = null!;

    private bool _linking;
    private string? _linkError;

    private async Task<NationalRegisterSearchResult> SearchAsync(NrSearchFormCriteria criteria)
    {
        var response = await RegistrationApi.SearchNationalRegisterAsync(
            new SearchNationalRegisterRequest(
                criteria.GivenName,
                criteria.FamilyName,
                criteria.BirthDate,
                criteria.Page,
                criteria.PageSize),
            CancellationToken.None);

        return new NationalRegisterSearchResult(
            response.Matches.Select(Map).ToList(),
            response.TotalCount,
            response.Page,
            response.PageSize);
    }

    private async Task LinkMatch(NationalRegisterSearchMatch match)
    {
        _linking = true;
        _linkError = null;

        try
        {
            await RegistrationApi.LinkExistingPersonAsync(
                CaseId,
                new LinkExistingPersonRequest(match.RegisterPersonId),
                CancellationToken.None);

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (ValidationException ex)
        {
            _linkError = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            _linkError = ex.Message;
        }
        catch (NationalRegisterConflictException ex)
        {
            _linkError = ex.Message;
        }
        catch (KeyNotFoundException ex)
        {
            _linkError = ex.Message;
        }
        finally
        {
            _linking = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private static NationalRegisterSearchMatch Map(NationalRegisterMatchDto match)
    {
        return new NationalRegisterSearchMatch(
            match.RegisterPersonId,
            match.GivenName,
            match.FamilyName,
            match.BirthDate,
            match.BisNumber,
            match.NationalRegisterNumber,
            match.MatchScore,
            match.MatchReason,
            match.IsRegisteredInPopulation,
            match.PersonId,
            match.IsDeceased);
    }

}