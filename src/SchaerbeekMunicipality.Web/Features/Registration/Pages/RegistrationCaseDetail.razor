@page "/registration/cases/{CaseId:guid}"
@using SchaerbeekMunicipality.Web.Features.Registration.AttachDocument
@using SchaerbeekMunicipality.Web.Features.Registration.Components
@using SchaerbeekMunicipality.Web.Features.Registration.GetRegistrationCase
@using SchaerbeekMunicipality.Web.Features.Registration.RecordIdentity
@inject GetRegistrationCaseHandler GetHandler
@inject RecordIdentityHandler RecordIdentityHandler
@inject AttachDocumentHandler AttachDocumentHandler
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Case @CaseId</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_case is null)
{
    <MudAlert Severity="Severity.Error">Registration case not found.</MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                   Variant="Variant.Text"
                   OnClick="@(() => Navigation.NavigateTo("/registration/cases"))">
            Back to list
        </MudButton>
        <MudSpacer />
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">@_case.Status</MudChip>
    </MudStack>

    <MudText Typo="Typo.h4" GutterBottom="true">Registration case</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        @CaseId.ToString()[..8]… · @_case.VisitReason · opened @_case.OpenedAt.LocalDateTime.ToString("g")
    </MudText>

    <MudPaper Class="pa-4 mb-4" Outlined="true">
        <MudText Typo="Typo.h6" GutterBottom="true">Completeness checklist</MudText>
        <MudStack Row="true" Spacing="2">
            <MudChip T="string" Color="@ChecklistColor(_case.Checklist.IdentityEstablished)" Size="Size.Small">
                Identity @(_case.Checklist.IdentityEstablished ? "✓" : "—")
            </MudChip>
            <MudChip T="string" Color="@ChecklistColor(_case.Checklist.LegalResidenceEstablished)" Size="Size.Small">
                Legal residence @(_case.Checklist.LegalResidenceEstablished ? "✓" : "—")
            </MudChip>
            <MudChip T="string" Color="@ChecklistColor(_case.Checklist.AddressDeclared)" Size="Size.Small">
                Address @(_case.Checklist.AddressDeclared ? "✓" : "—")
            </MudChip>
        </MudStack>
    </MudPaper>

    @if (_case.Person is null)
    {
        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <MudText Typo="Typo.h6" GutterBottom="true">Identity</MudText>
            <MudForm @ref="_identityForm" @bind-IsValid="_identityFormValid">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_givenName" Label="Given name" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_familyName" Label="Family name" Required="true" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="_birthDate" Label="Date of birth" Required="true" MaxDate="DateTime.Today" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_nationality" Label="Nationality" Required="true" />
                    </MudItem>
                </MudGrid>
                <MudButton Class="mt-3"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="_savingIdentity"
                           OnClick="SaveIdentity">
                    Record identity
                </MudButton>
            </MudForm>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <MudText Typo="Typo.h6" GutterBottom="true">Identity</MudText>
            <MudText Typo="Typo.body1">@_case.Person.GivenName @_case.Person.FamilyName</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Born @_case.Person.BirthDate.ToString("d") · @_case.Person.Nationality
            </MudText>
        </MudPaper>
    }

    <DocumentUpload CaseId="CaseId"
                    Handler="AttachDocumentHandler"
                    OnUploaded="ReloadCase" />

    @if (_case.Documents.Count > 0)
    {
        <MudPaper Class="pa-4" Outlined="true">
            <MudText Typo="Typo.h6" GutterBottom="true">Attached documents</MudText>
            <MudList T="string" Dense="true">
                @foreach (var doc in _case.Documents)
                {
                    <MudListItem T="string" Icon="@Icons.Material.Filled.AttachFile">
                        @doc.DocumentType — @doc.FileName
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @doc.UploadedAt.LocalDateTime.ToString("g")
                        </MudText>
                    </MudListItem>
                }
            </MudList>
        </MudPaper>
    }
}

@code {
    [Parameter]
    public Guid CaseId { get; set; }

    private RegistrationCaseDetailDto? _case;
    private bool _loading = true;
    private MudForm _identityForm = null!;
    private bool _identityFormValid;
    private bool _savingIdentity;

    private string _givenName = string.Empty;
    private string _familyName = string.Empty;
    private DateTime? _birthDate;
    private string _nationality = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        await ReloadCase();
    }

    private async Task ReloadCase()
    {
        _loading = true;
        _case = await GetHandler.Handle(
            new Domain.Registration.RegistrationCaseId(CaseId),
            CancellationToken.None);
        _loading = false;
    }

    private async Task SaveIdentity()
    {
        await _identityForm.Validate();
        if (!_identityFormValid || _birthDate is null)
        {
            return;
        }

        _savingIdentity = true;
        try
        {
            var request = new RecordIdentityRequest(
                _givenName,
                _familyName,
                DateOnly.FromDateTime(_birthDate.Value),
                _nationality);

            await RecordIdentityHandler.Handle(
                new Domain.Registration.RegistrationCaseId(CaseId),
                request,
                CancellationToken.None);

            Snackbar.Add("Identity recorded.", Severity.Success);
            await ReloadCase();
        }
        catch (FluentValidation.ValidationException ex)
        {
            Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error);
        }
        catch (Domain.Registration.InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingIdentity = false;
        }
    }

    private static Color ChecklistColor(bool complete) =>
        complete ? Color.Success : Color.Default;
}
