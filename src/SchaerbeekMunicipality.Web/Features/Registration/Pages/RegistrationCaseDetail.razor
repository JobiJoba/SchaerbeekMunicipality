@page "/registration/cases/{CaseId:guid}"
@using SchaerbeekMunicipality.Web.Features.Registration.AttachDocument
@using SchaerbeekMunicipality.Web.Features.Registration.ConvertBisNumber
@using SchaerbeekMunicipality.Web.Features.Registration.CorrectIdentity
@using SchaerbeekMunicipality.Web.Features.Registration.GetRegistrationCase
@using SchaerbeekMunicipality.Web.Features.Registration.LinkExistingPerson
@using SchaerbeekMunicipality.Web.Features.Registration.RecordIdentity
@using SchaerbeekMunicipality.Web.Features.Registration.RequestPoliceVerification
@using SchaerbeekMunicipality.Web.Features.Registration.RemoveDocument
@using SchaerbeekMunicipality.Web.Features.Registration.SearchNationalRegister
@using SchaerbeekMunicipality.Domain.Documents
@using SchaerbeekMunicipality.Domain.NationalRegister
@using SchaerbeekMunicipality.Domain.Police
@using SchaerbeekMunicipality.Web.DesignSystem.Components.Dialogs
@inject GetRegistrationCaseHandler GetHandler
@inject RecordIdentityHandler RecordIdentityHandler
@inject CorrectIdentityHandler CorrectIdentityHandler
@inject SearchNationalRegisterHandler SearchNationalRegisterHandler
@inject LinkExistingPersonHandler LinkExistingPersonHandler
@inject ConvertBisNumberHandler ConvertBisNumberHandler
@inject RequestPoliceVerificationHandler RequestPoliceVerificationHandler
@inject AttachDocumentHandler AttachDocumentHandler
@inject RemoveDocumentHandler RemoveDocumentHandler
@inject IAppDialogService DialogService
@inject IDialogService MudDialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<AppPage Title="Registration case" MaxWidth="MaxWidth.False">
    @if (_loading)
    {
        <AppLoading />
    }
    else if (_case is null)
    {
        <AppAlert Severity="Severity.Error" Title="Not found">
            Registration case not found.
        </AppAlert>
    }
    else
    {
        <AppPageHeader Title="Registration case"
                       Subtitle="@($"{CaseId.ToString()[..8]}… · {_case.VisitReason} · opened {_case.OpenedAt.LocalDateTime:g}")">
            <StatusChip>
                <AppStatusChip Status="_case.Status" />
            </StatusChip>
            <Actions>
                @if (CanSendToPolice)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.LocalPolice"
                               Disabled="_sendingToPolice"
                               OnClick="SendToPolice">
                        Send to police
                    </MudButton>
                }
                <MudButton StartIcon="@Icons.Material.Outlined.ArrowBack"
                           Variant="Variant.Text"
                           OnClick="@(() => Navigation.NavigateTo("/registration/cases"))">
                    Back to list
                </MudButton>
            </Actions>
        </AppPageHeader>

        <AppSection Title="Completeness checklist">
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <AppStatusChip Label="@($"Identity {(_case.Checklist.IdentityEstablished ? "✓" : "—")}")"
                               Severity="@(_case.Checklist.IdentityEstablished ? AppSeverity.Success : AppSeverity.Neutral)" />
                <AppStatusChip Label="@($"Legal residence {(_case.Checklist.LegalResidenceEstablished ? "✓" : "—")}")"
                               Severity="@(_case.Checklist.LegalResidenceEstablished ? AppSeverity.Success : AppSeverity.Neutral)" />
                <AppStatusChip Label="@($"Address {(_case.Checklist.AddressDeclared ? "✓" : "—")}")"
                               Severity="@(_case.Checklist.AddressDeclared ? AppSeverity.Success : AppSeverity.Neutral)" />
                <AppStatusChip Label="@($"Address confirmed {(_case.Checklist.AddressConfirmed ? "✓" : "—")}")"
                               Severity="@(_case.Checklist.AddressConfirmed ? AppSeverity.Success : (_case.Status == RegistrationCaseStatus.AwaitingPoliceVerification ? AppSeverity.Warning : AppSeverity.Neutral))" />
            </MudStack>
        </AppSection>

        @if (_case.Status == RegistrationCaseStatus.AwaitingPoliceVerification)
        {
            <AppSection>
                <AppAlert Severity="Severity.Info"
                          Title="Awaiting police verification"
                          Class="mb-0">
                    This case has been sent to the local police for a residence check.
                    @if (_case.ActivePoliceVerification is not null)
                    {
                        <text> Request sent @_case.ActivePoliceVerification.RequestedAt.LocalDateTime.ToString("g") (attempt @_case.ActivePoliceVerification.AttemptNumber).</text>
                    }
                </AppAlert>
            </AppSection>
        }

        <PoliceVerificationSection ActiveVerification="_case.ActivePoliceVerification"
                                   History="_case.PoliceVerificationHistory" />

        @if (_case.Person is not null && _case.PossibleDuplicateMatches.Count > 0 && !_case.Person.LinkedFromRegister)
        {
            <AppSection>
                <AppAlert Severity="Severity.Warning"
                          Title="Possible duplicate detected"
                          Class="mb-0">
                    @_case.PossibleDuplicateMatches.Count possible match(es) found in the National Register for this identity.
                    Review before proceeding — linking an existing record avoids duplicate person files.
                    <MudButton Variant="Variant.Text"
                               Color="Color.Warning"
                               Class="mt-2"
                               StartIcon="@Icons.Material.Outlined.Search"
                               OnClick="OpenNationalRegisterSearch">
                        Review matches
                    </MudButton>
                </AppAlert>
            </AppSection>
        }

        <MudGrid Spacing="4">
            <MudItem xs="12" lg="7">
        @if (_case.Person is null)
        {
            <AppSection>
                <AppCard Title="Identity" Outlined="true">
                    <HeaderActions>
                        <MudButton StartIcon="@Icons.Material.Outlined.Search"
                                   Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   OnClick="OpenNationalRegisterSearch">
                            Search National Register
                        </MudButton>
                    </HeaderActions>
                    <ChildContent>
                    <MudForm @ref="_identityForm" @bind-IsValid="_identityFormValid">
                        <AppFormSection Title="Personal details">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_givenName" Label="Given name" Required="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_familyName" Label="Family name" Required="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker @bind-Date="_birthDate" Label="Date of birth" Required="true" MaxDate="DateTime.Today" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_nationality" Label="Nationality" Required="true" />
                            </MudItem>
                        </AppFormSection>

                        <AppInfoBox Class="mb-4">
                            Search the National Register first when the person may already have a BIS or NR record.
                            Record identity only when you have verified the supporting documents on file.
                        </AppInfoBox>

                        <AppSaveCancelBar SaveText="Record identity"
                                          CancelText="Clear"
                                          Saving="_savingIdentity"
                                          OnSave="SaveIdentity"
                                          OnCancel="ClearIdentityForm" />
                    </MudForm>
                    </ChildContent>
                </AppCard>
            </AppSection>
        }
        else if (_editingIdentity)
        {
            <AppSection>
                <AppCard Title="Identity" Outlined="true">
                    <MudForm @ref="_identityForm" @bind-IsValid="_identityFormValid">
                        <AppFormSection Title="Personal details">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_givenName" Label="Given name" Required="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_familyName" Label="Family name" Required="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker @bind-Date="_birthDate" Label="Date of birth" Required="true" MaxDate="DateTime.Today" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_nationality" Label="Nationality" Required="true" />
                            </MudItem>
                        </AppFormSection>

                        <AppSaveCancelBar SaveText="Save changes"
                                          CancelText="Cancel"
                                          Saving="_savingIdentity"
                                          Disabled="!IdentityFormDirty"
                                          OnSave="SaveIdentityCorrection"
                                          OnCancel="CancelIdentityEdit" />
                    </MudForm>
                </AppCard>
            </AppSection>
        }
        else
        {
            <AppSection>
                <AppCard Title="Identity" Outlined="true">
                    <HeaderActions>
                        @if (CanEditIntakeData)
                        {
                            <MudButton StartIcon="@Icons.Material.Outlined.Edit"
                                       Variant="Variant.Text"
                                       OnClick="StartEditingIdentity"
                                       aria-label="Edit identity">
                                Edit
                            </MudButton>
                        }
                    </HeaderActions>
                    <ChildContent>
                        <MudText Typo="Typo.body1">@_case.Person.GivenName @_case.Person.FamilyName</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Born @_case.Person.BirthDate.ToString("d") · @_case.Person.Nationality
                        </MudText>
                        @if (_case.Person.LinkedFromRegister)
                        {
                            <AppStatusChip Label="Linked from National Register"
                                           Severity="AppSeverity.Info"
                                           Class="mt-2" />
                        }
                        @if (!string.IsNullOrWhiteSpace(_case.Person.BisNumber))
                        {
                            <MudText Typo="Typo.body2" Class="mt-2">
                                BIS @FormatRegisterNumber(_case.Person.BisNumber)
                            </MudText>
                        }
                        @if (!string.IsNullOrWhiteSpace(_case.Person.NationalRegisterNumber))
                        {
                            <MudText Typo="Typo.body2" Class="mt-1">
                                NR @FormatRegisterNumber(_case.Person.NationalRegisterNumber)
                            </MudText>
                        }
                        @if (CanConvertBis)
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Class="mt-3"
                                       StartIcon="@Icons.Material.Outlined.SwapHoriz"
                                       Disabled="_convertingBis"
                                       OnClick="ConvertBis">
                                Convert BIS to National Register number
                            </MudButton>
                        }
                    </ChildContent>
                </AppCard>
            </AppSection>
        }

        <ResidenceStep Case="_case" CaseId="CaseId" CanEdit="CanEditIntakeData" OnUpdated="ReloadCase" />

        <AddressStep Case="_case" CaseId="CaseId" CanEdit="CanEditIntakeData" OnUpdated="ReloadCase" />

        <HouseholdStep Case="_case" CaseId="CaseId" CanEdit="CanEditIntakeData" OnUpdated="ReloadCase" />

        <CivilStatusStep Case="_case" CaseId="CaseId" CanEdit="CanEditIntakeData" OnUpdated="ReloadCase" />

            </MudItem>

            <MudItem xs="12" lg="5">
                <RegistrationCaseDocumentPanel CaseId="CaseId"
                                               Documents="_case.Documents"
                                               AttachHandler="AttachDocumentHandler"
                                               CanEdit="CanEditIntakeData"
                                               OnRemoveDocument="RemoveDocument"
                                               OnUploaded="ReloadCase" />
            </MudItem>
        </MudGrid>
    }
</AppPage>

@code {
    [Parameter]
    public Guid CaseId { get; set; }

    private RegistrationCaseDetailDto? _case;
    private bool _loading = true;
    private bool _editingIdentity;
    private MudForm _identityForm = null!;
    private bool _identityFormValid;
    private bool _savingIdentity;
    private bool _convertingBis;
    private bool _sendingToPolice;

    private string _givenName = string.Empty;
    private string _familyName = string.Empty;
    private DateTime? _birthDate;
    private string _nationality = string.Empty;

    private bool CanEditIntakeData =>
        _case is not null &&
        _case.Status is RegistrationCaseStatus.Intake or RegistrationCaseStatus.UnderReview;

    private bool CanConvertBis =>
        CanEditIntakeData &&
        _case?.Person is { BisNumber: not null, NationalRegisterNumber: null };

    private bool CanSendToPolice =>
        _case is not null &&
        _case.Checklist.IdentityEstablished &&
        _case.Checklist.AddressDeclared &&
        _case.ActivePoliceVerification is null &&
        _case.Status is RegistrationCaseStatus.Intake or RegistrationCaseStatus.UnderReview;

    private bool IdentityFormDirty =>
        _case?.Person is not null &&
        (_givenName != _case.Person.GivenName ||
         _familyName != _case.Person.FamilyName ||
         _birthDate?.Date != _case.Person.BirthDate.ToDateTime(TimeOnly.MinValue).Date ||
         _nationality != _case.Person.Nationality);

    protected override async Task OnParametersSetAsync()
    {
        await ReloadCase();
    }

    private async Task ReloadCase()
    {
        _loading = true;
        _editingIdentity = false;
        _case = await GetHandler.Handle(
            new RegistrationCaseId(CaseId),
            CancellationToken.None);
        _loading = false;
    }

    private void ClearIdentityForm()
    {
        _givenName = string.Empty;
        _familyName = string.Empty;
        _birthDate = null;
        _nationality = string.Empty;
    }

    private void StartEditingIdentity()
    {
        if (_case?.Person is null)
        {
            return;
        }

        _givenName = _case.Person.GivenName;
        _familyName = _case.Person.FamilyName;
        _birthDate = _case.Person.BirthDate.ToDateTime(TimeOnly.MinValue);
        _nationality = _case.Person.Nationality;
        _editingIdentity = true;
    }

    private async Task CancelIdentityEdit()
    {
        if (IdentityFormDirty)
        {
            var confirmed = await DialogService.ConfirmAsync(
                "Discard changes?",
                "You have unsaved identity changes.",
                "Discard");

            if (!confirmed)
            {
                return;
            }
        }

        _editingIdentity = false;
    }

    private async Task SaveIdentity()
    {
        await _identityForm.Validate();
        if (!_identityFormValid || _birthDate is null)
        {
            return;
        }

        _savingIdentity = true;
        try
        {
            var request = new RecordIdentityRequest(
                _givenName,
                _familyName,
                DateOnly.FromDateTime(_birthDate.Value),
                _nationality);

            await RecordIdentityHandler.Handle(
                new RegistrationCaseId(CaseId),
                request,
                CancellationToken.None);

            Snackbar.Add("Identity recorded.", Severity.Success);
            await ReloadCase();
        }
        catch (FluentValidation.ValidationException ex)
        {
            Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error);
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingIdentity = false;
        }
    }

    private async Task SaveIdentityCorrection()
    {
        await _identityForm.Validate();
        if (!_identityFormValid || _birthDate is null)
        {
            return;
        }

        _savingIdentity = true;
        try
        {
            var request = new RecordIdentityRequest(
                _givenName,
                _familyName,
                DateOnly.FromDateTime(_birthDate.Value),
                _nationality);

            var response = await CorrectIdentityHandler.Handle(
                new RegistrationCaseId(CaseId),
                request,
                CancellationToken.None);

            Snackbar.Add("Identity updated.", Severity.Success);
            if (!string.IsNullOrWhiteSpace(response.PolicyMessage))
            {
                Snackbar.Add(response.PolicyMessage, Severity.Warning);
            }

            await ReloadCase();
        }
        catch (FluentValidation.ValidationException ex)
        {
            Snackbar.Add(string.Join(" ", ex.Errors.Select(e => e.ErrorMessage)), Severity.Error);
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingIdentity = false;
        }
    }

    private async Task OpenNationalRegisterSearch()
    {
        var parameters = new DialogParameters<NationalRegisterSearchDialog>
        {
            { x => x.CaseId, CaseId },
            { x => x.SearchHandler, SearchNationalRegisterHandler },
            { x => x.LinkHandler, LinkExistingPersonHandler },
            { x => x.InitialGivenName, string.IsNullOrWhiteSpace(_givenName) ? null : _givenName },
            { x => x.InitialFamilyName, string.IsNullOrWhiteSpace(_familyName) ? null : _familyName },
            { x => x.InitialBirthDate, _birthDate.HasValue ? DateOnly.FromDateTime(_birthDate.Value) : null },
        };

        var dialog = await MudDialogService.ShowAsync<NationalRegisterSearchDialog>(
            "Search National Register",
            parameters,
            AppDialogOptions.Large);

        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            Snackbar.Add("Existing register record linked.", Severity.Success);
            await ReloadCase();
        }
    }

    private async Task ConvertBis()
    {
        _convertingBis = true;
        try
        {
            var response = await ConvertBisNumberHandler.Handle(
                new RegistrationCaseId(CaseId),
                CancellationToken.None);

            Snackbar.Add($"BIS converted to NR {FormatRegisterNumber(response.NationalRegisterNumber)}.", Severity.Success);
            await ReloadCase();
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (NationalRegisterConflictException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _convertingBis = false;
        }
    }

    private async Task SendToPolice()
    {
        var confirmed = await DialogService.ConfirmAsync(
            "Send to police?",
            "The local police will verify that the person actually resides at the declared address.",
            "Send to police",
            consequence: "The case will be locked for intake edits until the police clerk records a result.");

        if (!confirmed)
        {
            return;
        }

        _sendingToPolice = true;
        try
        {
            await RequestPoliceVerificationHandler.Handle(
                new RegistrationCaseId(CaseId),
                CancellationToken.None);

            Snackbar.Add("Case sent to police for residence verification.", Severity.Success);
            await ReloadCase();
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (InvalidPoliceVerificationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _sendingToPolice = false;
        }
    }

    private static string FormatRegisterNumber(string value) =>
        value.Length == 11
            ? $"{value[..6]}-{value[6..9]}.{value[9..]}"
            : value;

    private async Task RemoveDocument(Guid documentId)
    {
        var confirmed = await DialogService.ConfirmAsync(
            "Remove document?",
            "This will permanently delete the attached file.",
            "Remove",
            destructive: true,
            consequence: "The document cannot be recovered after removal.");

        if (!confirmed)
        {
            return;
        }

        try
        {
            await RemoveDocumentHandler.Handle(
                new RegistrationCaseId(CaseId),
                new AdministrativeDocumentId(documentId),
                CancellationToken.None);

            Snackbar.Add("Document removed.", Severity.Success);
            await ReloadCase();
        }
        catch (InvalidRegistrationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (KeyNotFoundException)
        {
            Snackbar.Add("Document not found.", Severity.Error);
            await ReloadCase();
        }
    }
}
