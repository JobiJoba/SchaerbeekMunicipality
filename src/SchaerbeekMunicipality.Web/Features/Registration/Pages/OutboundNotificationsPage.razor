@page "/administration/outbound-notifications"
@using SchaerbeekMunicipality.Application.Features.Registration.ListOutboundNotifications
@using SchaerbeekMunicipality.Web.Api.Registration
@inject IRegistrationApi RegistrationApi
@inject NavigationManager Navigation

<AppPage Title="Outbound notifications" MaxWidth="MaxWidth.Large">
    <AppPageHeader Title="Outbound notifications"
                   Subtitle="Simulated messages to other Belgian administrations after registration is confirmed.">
        <Actions>
            <MudButton StartIcon="@Icons.Material.Outlined.ArrowBack"
                       Variant="Variant.Text"
                       OnClick="@(() => Navigation.NavigateTo("/registration/cases"))">
                Back to cases
            </MudButton>
        </Actions>
    </AppPageHeader>

    @if (_loading)
    {
        <AppLoading/>
    }
    else if (_notifications.Count == 0)
    {
        <AppEmptyState Icon="@Icons.Material.Outlined.NotificationsNone"
                       Title="No outbound notifications yet"
                       Description="Notifications are created automatically when registration, birth declaration, or change of address cases are completed."/>
    }
    else
    {
        <AppSection Title="@($"{_notifications.Count} notification(s)")">
            <MudTable Items="_notifications" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Created</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Recipient</MudTh>
                    <MudTh>Message</MudTh>
                    <MudTh>Case</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Created">@context.CreatedAt.LocalDateTime:g</MudTd>
                    <MudTd DataLabel="Status">
                        <AppStatusChip Label="@FormatDeliveryStatus(context.DeliveryStatus)"
                                       Severity="@GetDeliverySeverity(context.DeliveryStatus)"/>
                        @if (context.AttemptCount > 0 && context.DeliveryStatus is not "Sent")
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                Attempt @context.AttemptCount
                            </MudText>
                        }
                        @if (!string.IsNullOrWhiteSpace(context.LastError))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">@context.LastError</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Recipient">
                        <AppStatusChip Label="@FormatRecipient(context.Recipient)" Severity="AppSeverity.Info"/>
                    </MudTd>
                    <MudTd DataLabel="Message">@context.Message</MudTd>
                    <MudTd DataLabel="Case">
                        <MudLink Href="@GetCaseHref(context)">
                            @FormatCaseType(context.CaseType) — @context.CaseId.ToString()[..8]…
                        </MudLink>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </AppSection>
    }
</AppPage>

@code {
    private bool _loading = true;
    private IReadOnlyList<OutboundNotificationDto> _notifications = [];

    protected override async Task OnInitializedAsync()
    {
        var response = await RegistrationApi.ListOutboundNotificationsAsync(cancellationToken: CancellationToken.None);
        _notifications = response.Items;
        _loading = false;
    }

    private static string FormatRecipient(string recipient)
    {
        return recipient switch
        {
            "TaxAdministration" => "Tax administration",
            "SocialSecurity" => "Social security",
            "HealthInsurance" => "Health insurance",
            _ => recipient
        };
    }

    private static string FormatDeliveryStatus(string status)
    {
        return status switch
        {
            "Pending" => "Pending",
            "Processing" => "Processing",
            "Sent" => "Sent",
            "Failed" => "Failed",
            _ => status
        };
    }

    private static AppSeverity GetDeliverySeverity(string status)
    {
        return status switch
        {
            "Sent" => AppSeverity.Success,
            "Failed" => AppSeverity.Error,
            "Processing" => AppSeverity.Info,
            _ => AppSeverity.Warning
        };
    }

    private static string GetCaseHref(OutboundNotificationDto notification)
    {
        return notification.CaseType switch
        {
            OutboundNotificationCaseType.BirthDeclaration => $"/birth-declarations/{notification.CaseId}",
            OutboundNotificationCaseType.ChangeOfAddress => $"/change-of-address/{notification.CaseId}",
            _ => $"/registration/cases/{notification.CaseId}"
        };
    }

    private static string FormatCaseType(OutboundNotificationCaseType caseType)
    {
        return caseType switch
        {
            OutboundNotificationCaseType.BirthDeclaration => "Birth declaration",
            OutboundNotificationCaseType.ChangeOfAddress => "Change of address",
            _ => "Registration"
        };
    }

}