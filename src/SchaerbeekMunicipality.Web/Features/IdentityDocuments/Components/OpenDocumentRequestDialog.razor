@using FluentValidation
@using SchaerbeekMunicipality.Application.Features.IdentityDocuments.OpenDocumentRequestCase
@using SchaerbeekMunicipality.Application.Features.IdentityDocuments.ResolveRegisteredPerson
@using SchaerbeekMunicipality.Domain.IdentityDocuments
@using SchaerbeekMunicipality.Web.Api.IdentityDocuments
@using Severity = MudBlazor.Severity
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h4">New document request</MudText>
    </TitleContent>
    <DialogContent>
        <MudSelect T="DocumentRequestType" @bind-Value="_requestType" Label="Request type" Required="true" Class="mb-4">
            @foreach (var type in Enum.GetValues<DocumentRequestType>())
            {
                <MudSelectItem Value="type">@type.ToDisplayString()</MudSelectItem>
            }
        </MudSelect>

        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Search the National Register to identify a registered resident.
        </MudText>

        <NationalRegisterSearchForm ShowBirthDateColumn="false"
                                    NumberColumnTitle="NR number"
                                    SearchAsync="SearchAsync">
            <RowActions Context="match">
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           Disabled="_opening"
                           data-testid="open-document-request-case"
                           OnClick="@(() => OpenCase(match))">
                    Open case
                </MudButton>
            </RowActions>
        </NationalRegisterSearchForm>

        @if (!string.IsNullOrWhiteSpace(_actionError))
        {
            <AppAlert Severity="Severity.Error" Title="Error" Class="mt-4">@_actionError</AppAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Inject] private INationalRegisterSearchQueries NationalRegisterSearch { get; set; } = null!;
    [Inject] private IIdentityDocumentsApi IdentityDocumentsApi { get; set; } = null!;

    private bool _opening;
    private string? _actionError;
    private DocumentRequestType _requestType = DocumentRequestType.IdentityCardRenewal;

    private Task<NationalRegisterSearchResult> SearchAsync(NrSearchFormCriteria criteria) =>
        NationalRegisterSearch.SearchRegisteredResidentsAsync(criteria);

    private async Task OpenCase(NationalRegisterSearchMatch match)
    {
        _opening = true;
        _actionError = null;
        try
        {
            var resolved = await IdentityDocumentsApi.ResolveRegisteredPersonAsync(
                new ResolveRegisteredPersonRequest(match.RegisterPersonId),
                CancellationToken.None);

            var opened = await IdentityDocumentsApi.OpenRequestAsync(
                new OpenDocumentRequestCaseRequest(resolved.PersonId, _requestType),
                CancellationToken.None);

            MudDialog.Close(DialogResult.Ok(opened.CaseId));
        }
        catch (Exception ex) when (ex is InvalidDocumentRequestTransitionException or InvalidOperationException or KeyNotFoundException or ValidationException)
        {
            _actionError = ex is ValidationException validation
                ? string.Join(" ", validation.Errors.Select(e => e.ErrorMessage))
                : ex.Message;
        }
        finally
        {
            _opening = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

}