@using SchaerbeekMunicipality.Domain.IdentityDocuments
@using SchaerbeekMunicipality.Web.Api.IdentityDocuments
<AppCard Title="Applicant photo" Outlined="true">
    <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png" FilesChanged="OnFileSelected">
        <CustomContent Context="fileUpload">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.Upload"
                       Disabled="!CanEdit"
                       OnClick="@fileUpload.OpenFilePickerAsync">
                Choose photo
            </MudButton>
        </CustomContent>
    </MudFileUpload>

    @if (_selectedFile is not null)
    {
        <MudText Typo="Typo.body2" Class="mt-2">Selected: @_selectedFile.Name</MudText>
    }

    @if (CanEdit)
    {
        <MudButton Class="mt-3"
                   Variant="Variant.Filled"
                   Color="Color.Secondary"
                   Disabled="_uploading || _selectedFile is null"
                   OnClick="Upload">
            Upload photo
        </MudButton>
    }
</AppCard>

@code {
    [Parameter] [EditorRequired] public Guid CaseId { get; set; }

    [Parameter] public bool CanEdit { get; set; }

    [Parameter] public EventCallback OnUploaded { get; set; }

    [Inject] private IIdentityDocumentsApi IdentityDocumentsApi { get; set; } = null!;

    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private IBrowserFile? _selectedFile;
    private bool _uploading;

    private Task OnFileSelected(IBrowserFile? file)
    {
        _selectedFile = file;
        return Task.CompletedTask;
    }

    private async Task Upload()
    {
        if (_selectedFile is null)
        {
            return;
        }

        _uploading = true;
        try
        {
            await using var stream = _selectedFile.OpenReadStream(10 * 1024 * 1024);
            await IdentityDocumentsApi.AttachApplicantPhotoAsync(
                CaseId,
                stream,
                _selectedFile.Name,
                CancellationToken.None);

            Snackbar.Add("Applicant photo uploaded.", Severity.Success);
            _selectedFile = null;
            await OnUploaded.InvokeAsync();
        }
        catch (InvalidDocumentRequestTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _uploading = false;
        }
    }

}