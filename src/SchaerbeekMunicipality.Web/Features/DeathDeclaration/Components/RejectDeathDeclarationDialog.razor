@using SchaerbeekMunicipality.Application.Features.DeathDeclaration.RejectDeathDeclaration
@using SchaerbeekMunicipality.Domain.DeathDeclaration
<ReasonNotesDialog TReason="DeathDeclarationRejectionReason"
                   TRequest="RejectDeathDeclarationRequest"
                   ReasonLabel="Rejection reason"
                   ConfirmText="Close case"
                   ConfirmColor="Color.Error"
                   FormatReason="FormatReason"
                   CreateRequest="CreateRequest"
                   InitialReason="@InitialReason"
                   InitialNotes="@InitialNotes"/>

@code {
    [Parameter] public DeathDeclarationRejectionReason? InitialReason { get; set; }

    [Parameter] public string? InitialNotes { get; set; }

    private static RejectDeathDeclarationRequest CreateRequest(DeathDeclarationRejectionReason reason, string? notes)
    {
        return new RejectDeathDeclarationRequest(reason, notes);
    }

    private static string FormatReason(DeathDeclarationRejectionReason reason)
    {
        return reason switch
        {
            DeathDeclarationRejectionReason.OpenedInError => "Opened in error (wrong person)",
            DeathDeclarationRejectionReason.MissingDeathAct => "Missing death act",
            DeathDeclarationRejectionReason.PersonAlreadyDeceased => "Person already deceased",
            DeathDeclarationRejectionReason.InsufficientEvidence => "Insufficient evidence",
            _ => "Other"
        };
    }
}
