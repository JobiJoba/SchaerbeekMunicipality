@using FluentValidation
@using SchaerbeekMunicipality.Application.Features.ChangeOfAddress.ResolveRegisteredPerson
@using SchaerbeekMunicipality.Application.Features.DeathDeclaration.OpenDeathDeclarationCase
@using SchaerbeekMunicipality.Domain.DeathDeclaration
@using SchaerbeekMunicipality.Web.Api.ChangeOfAddress
@using SchaerbeekMunicipality.Web.Api.DeathDeclaration
@using Severity = MudBlazor.Severity
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h4">New death declaration</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Search the National Register to identify the deceased resident.
        </MudText>

        <NationalRegisterSearchForm ShowBirthDateColumn="true"
                                    NumberColumnTitle="NR number"
                                    SearchAsync="SearchAsync">
            <RowActions Context="match">
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           Disabled="_opening"
                           data-testid="open-death-declaration-case"
                           OnClick="@(() => OpenCase(match))">
                    Open case
                </MudButton>
            </RowActions>
        </NationalRegisterSearchForm>

        @if (!string.IsNullOrWhiteSpace(_actionError))
        {
            <AppAlert Severity="Severity.Error" Title="Error" Class="mt-4">@_actionError</AppAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Inject] private INationalRegisterSearchQueries NationalRegisterSearch { get; set; } = null!;
    [Inject] private IChangeOfAddressApi ChangeOfAddressApi { get; set; } = null!;
    [Inject] private IDeathDeclarationApi DeathDeclarationApi { get; set; } = null!;

    private bool _opening;
    private string? _actionError;

    private Task<NationalRegisterSearchResult> SearchAsync(NrSearchFormCriteria criteria) =>
        NationalRegisterSearch.SearchRegisteredResidentsAsync(criteria);

    private async Task OpenCase(NationalRegisterSearchMatch match)
    {
        _opening = true;
        _actionError = null;
        try
        {
            var resolved = await ChangeOfAddressApi.ResolveRegisteredPersonAsync(
                new ResolveRegisteredPersonRequest(match.RegisterPersonId),
                CancellationToken.None);

            var opened = await DeathDeclarationApi.OpenCaseAsync(
                new OpenDeathDeclarationCaseRequest(resolved.PersonId),
                CancellationToken.None);

            MudDialog.Close(DialogResult.Ok(opened.CaseId));
        }
        catch (Exception ex) when (ex is InvalidDeathDeclarationTransitionException or InvalidOperationException or KeyNotFoundException or ValidationException)
        {
            _actionError = ex is ValidationException validation
                ? string.Join(" ", validation.Errors.Select(e => e.ErrorMessage))
                : ex.Message;
        }
        finally
        {
            _opening = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

}
