@using Microsoft.AspNetCore.Components.Forms
@using SchaerbeekMunicipality.Domain.BirthDeclaration
@using SchaerbeekMunicipality.Web.Api.BirthDeclaration

<AppCard Title="Attach medical declaration" Outlined="true">
    <MudFileUpload T="IBrowserFile" Accept=".pdf,.jpg,.jpeg,.png" FilesChanged="OnFileSelected">
        <CustomContent Context="fileUpload">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Upload"
                       OnClick="@fileUpload.OpenFilePickerAsync">
                Choose file
            </MudButton>
        </CustomContent>
    </MudFileUpload>

    @if (_selectedFile is not null)
    {
        <MudText Typo="Typo.body2" Class="mt-2">Selected: @_selectedFile.Name</MudText>
    }

    <MudButton Class="mt-3"
               Variant="Variant.Filled"
               Color="Color.Secondary"
               Disabled="_uploading || _selectedFile is null"
               OnClick="Upload">
        Upload
    </MudButton>
</AppCard>

@code {
    [Parameter, EditorRequired]
    public Guid CaseId { get; set; }

    [Parameter]
    public EventCallback OnUploaded { get; set; }

    [Inject]
    private IBirthDeclarationApi BirthDeclarationApi { get; set; } = null!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = null!;

    private IBrowserFile? _selectedFile;
    private bool _uploading;

    private void OnFileSelected(IBrowserFile file) => _selectedFile = file;

    private async Task Upload()
    {
        if (_selectedFile is null)
        {
            return;
        }

        _uploading = true;
        try
        {
            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            await BirthDeclarationApi.AttachDocumentAsync(
                CaseId,
                stream,
                _selectedFile.Name,
                CancellationToken.None);

            Snackbar.Add("Medical declaration uploaded.", Severity.Success);
            _selectedFile = null;
            await OnUploaded.InvokeAsync();
        }
        catch (InvalidBirthDeclarationTransitionException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _uploading = false;
        }
    }
}
