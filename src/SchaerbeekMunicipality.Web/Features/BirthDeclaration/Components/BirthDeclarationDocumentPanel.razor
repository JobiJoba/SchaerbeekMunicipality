@using SchaerbeekMunicipality.Web.Features.BirthDeclaration.AttachDocument
@using SchaerbeekMunicipality.Web.Features.BirthDeclaration.GetBirthDeclarationCase
@inject NavigationManager Navigation

<CaseDocumentPanel Documents="@MapDocuments()"
                   CanEdit="CanEdit"
                   GetDocumentUrl="GetDocumentUrl"
                   OnRemoveDocument="OnRemoveDocument"
                   ShowEmptyState="@(!CanEdit)"
                   EmptyTitle="No medical declaration attached"
                   EmptyDescription="The hospital or midwife document has not been uploaded yet.">
    <UploadContent>
        @if (CanEdit)
        {
            <MedicalDeclarationUpload CaseId="CaseId"
                                        Handler="AttachHandler"
                                        OnUploaded="OnUploaded" />
        }
    </UploadContent>
</CaseDocumentPanel>

@code {
    [Parameter, EditorRequired]
    public Guid CaseId { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyList<BirthDeclarationDocumentDto> Documents { get; set; } = [];

    [Parameter, EditorRequired]
    public AttachDocumentHandler AttachHandler { get; set; } = null!;

    [Parameter]
    public bool CanEdit { get; set; }

    [Parameter]
    public EventCallback<Guid> OnRemoveDocument { get; set; }

    [Parameter]
    public EventCallback OnUploaded { get; set; }

    private IReadOnlyList<CaseDocumentItem> MapDocuments() =>
        Documents.Select(d => new CaseDocumentItem(d.Id, d.FileName, d.UploadedAt)).ToList();

    private string GetDocumentUrl(Guid documentId) =>
        Navigation.ToAbsoluteUri($"/api/birth-declarations/cases/{CaseId}/documents/{documentId}").ToString();
}
