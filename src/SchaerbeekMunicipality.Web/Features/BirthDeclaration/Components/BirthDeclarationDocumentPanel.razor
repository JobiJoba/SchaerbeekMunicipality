@using SchaerbeekMunicipality.Application.Features.BirthDeclaration.GetBirthDeclarationCase
@inject NavigationManager Navigation

<CaseDocumentPanel Documents="@MapDocuments()"
                   CanEdit="CanEdit"
                   GetDocumentUrl="GetDocumentUrl"
                   OnRemoveDocument="OnRemoveDocument"
                   ShowEmptyState="@(!CanEdit)"
                   EmptyTitle="No medical declaration attached"
                   EmptyDescription="The hospital or midwife document has not been uploaded yet.">
    <UploadContent>
        @if (CanEdit)
        {
            <MedicalDeclarationUpload CaseId="CaseId"
                                      OnUploaded="OnUploaded"/>
        }
    </UploadContent>
</CaseDocumentPanel>

@code {
    [Parameter] [EditorRequired] public Guid CaseId { get; set; }

    [Parameter] [EditorRequired] public IReadOnlyList<BirthDeclarationDocumentDto> Documents { get; set; } = [];

    [Parameter] public bool CanEdit { get; set; }

    [Parameter] public EventCallback<Guid> OnRemoveDocument { get; set; }

    [Parameter] public EventCallback OnUploaded { get; set; }

    private IReadOnlyList<CaseDocumentItem> MapDocuments()
    {
        return Documents.Select(d => new CaseDocumentItem(d.Id, d.FileName, d.UploadedAt)).ToList();
    }

    private string GetDocumentUrl(Guid documentId)
    {
        return Navigation.ToAbsoluteUri($"/api/birth-declarations/cases/{CaseId}/documents/{documentId}").ToString();
    }

}