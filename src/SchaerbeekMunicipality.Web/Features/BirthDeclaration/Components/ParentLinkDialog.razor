@using SchaerbeekMunicipality.Domain.BirthDeclaration
@using SchaerbeekMunicipality.Domain.NationalRegister
@using SchaerbeekMunicipality.Web.Features.BirthDeclaration.GetBirthDeclarationCase
@using SchaerbeekMunicipality.Web.Features.BirthDeclaration.LinkParent
@using SchaerbeekMunicipality.Web.Features.Registration.SearchNationalRegister

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h4">Link parent — National Register search</MudText>
    </TitleContent>
    <DialogContent>
        <NationalRegisterSearchForm ShowBirthDateColumn="false"
                                    SearchAsync="SearchAsync">
            <LeadContent>
                <MudSelect T="ParentRole" @bind-Value="_role" Label="Parent role" Class="mb-3">
                    <MudSelectItem Value="ParentRole.Mother">Mother</MudSelectItem>
                    <MudSelectItem Value="ParentRole.Father">Father</MudSelectItem>
                    <MudSelectItem Value="ParentRole.CoParent">Co-parent</MudSelectItem>
                </MudSelect>
            </LeadContent>
            <RowActions Context="match">
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           Disabled="_linking"
                           OnClick="@(() => LinkMatch(match))">
                    Link
                </MudButton>
            </RowActions>
        </NationalRegisterSearchForm>

        @if (!string.IsNullOrWhiteSpace(_linkError))
        {
            <AppAlert Severity="Severity.Error" Title="Error" Class="mt-4">@_linkError</AppAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Guid CaseId { get; set; }
    [Parameter] public SearchNationalRegisterHandler SearchHandler { get; set; } = null!;
    [Parameter] public LinkParentHandler LinkHandler { get; set; } = null!;

    private ParentRole _role = ParentRole.Mother;
    private bool _linking;
    private string? _linkError;

    private async Task<IReadOnlyList<NationalRegisterSearchMatch>> SearchAsync(NrSearchFormCriteria criteria)
    {
        var response = await SearchHandler.Handle(
            new SearchNationalRegisterRequest(criteria.GivenName, criteria.FamilyName, criteria.BirthDate),
            CancellationToken.None);

        return response.Matches.Select(Map).ToList();
    }

    private async Task LinkMatch(NationalRegisterSearchMatch match)
    {
        _linking = true;
        _linkError = null;
        try
        {
            await LinkHandler.Handle(
                new BirthDeclarationCaseId(CaseId),
                new LinkParentRequest(match.RegisterPersonId, _role),
                CancellationToken.None);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) when (ex is InvalidBirthDeclarationTransitionException or NationalRegisterConflictException or FluentValidation.ValidationException)
        {
            _linkError = ex is FluentValidation.ValidationException validation
                ? string.Join(" ", validation.Errors.Select(e => e.ErrorMessage))
                : ex.Message;
        }
        finally
        {
            _linking = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private static NationalRegisterSearchMatch Map(NationalRegisterMatchDto match) =>
        new(
            match.RegisterPersonId,
            match.GivenName,
            match.FamilyName,
            match.BirthDate,
            match.BisNumber,
            match.NationalRegisterNumber,
            match.MatchScore,
            match.MatchReason);
}
