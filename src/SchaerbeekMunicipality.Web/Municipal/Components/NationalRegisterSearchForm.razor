@using FluentValidation
@using Severity = MudBlazor.Severity
@if (LeadContent is not null)
{
    @LeadContent
}

<AppFormSection Title="Search criteria">
    <MudItem xs="12" md="6">
        <MudTextField @bind-Value="_givenName" Label="Given name"/>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudTextField @bind-Value="_familyName" Label="Family name" data-testid="nr-search-family-name"/>
    </MudItem>
    <MudItem xs="12" md="6">
        <AppDateField @bind-Value="_birthDate"
                      Label="Date of birth"
                      MaxDate="@DateTime.Today"
                      Clearable="true"/>
    </MudItem>
</AppFormSection>

<MudStack Row="true" Spacing="2" Class="mb-4">
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Outlined.Search"
               data-testid="nr-search-submit"
               OnClick="Search"
               Disabled="_searching">
        Search
    </MudButton>
</MudStack>

@if (_searched && _totalCount == 0)
{
    <AppInfoBox>@NoMatchesMessage</AppInfoBox>
}
else if (_searched && _matches.Count > 0)
{
    <MudText Typo="Typo.subtitle2" Class="mb-2">Possible matches</MudText>
    <MudTable Items="_matches" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            @if (ShowBirthDateColumn)
            {
                <MudTh>Birth date</MudTh>
            }
            <MudTh>@NumberColumnTitle</MudTh>
            @if (ShowMatchScore)
            {
                <MudTh>Score</MudTh>
            }
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate Context="match">
            <MudTd DataLabel="Name">@match.GivenName @match.FamilyName</MudTd>
            @if (ShowBirthDateColumn)
            {
                <MudTd DataLabel="Birth date">@match.BirthDate.ToString("d")</MudTd>
            }
            <MudTd DataLabel="@NumberColumnTitle">
                @if (ShowFormattedNumbers)
                {
                    @if (!string.IsNullOrWhiteSpace(match.NationalRegisterNumber))
                    {
                        <MudText Typo="Typo.body2">NR @NationalRegisterFormatting.FormatNumber(match.NationalRegisterNumber)</MudText>
                    }
                    else if (!string.IsNullOrWhiteSpace(match.BisNumber))
                    {
                        <MudText Typo="Typo.body2">BIS @NationalRegisterFormatting.FormatNumber(match.BisNumber)</MudText>
                    }
                }
                else
                {
                    @(match.NationalRegisterNumber ?? match.BisNumber ?? "—")
                }
            </MudTd>
            @if (ShowMatchScore)
            {
                <MudTd DataLabel="Score">
                    @if (match.MatchScore > 0)
                    {
                        <AppStatusChip Label="@($"{match.MatchScore}%")"
                                       Severity="@(match.MatchScore >= 100 ? AppSeverity.Success : AppSeverity.Warning)"/>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@match.MatchReason</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@match.MatchReason</MudText>
                    }
                </MudTd>
            }
            <MudTd>
                @if (RowActions is not null)
                {
                    @RowActions(match)
                }
            </MudTd>
        </RowTemplate>
    </MudTable>

    @if (_totalCount > _pageSize)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mt-2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @GetResultsRangeLabel()
            </MudText>
            <MudPagination Count="@TotalPages"
                           Selected="@_page"
                           SelectedChanged="OnPageChanged"
                           Disabled="_searching"/>
        </MudStack>
    }
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <AppAlert Severity="Severity.Error" Title="Error" Class="mt-4">@_error</AppAlert>
}

@code {
    [Parameter] public string? InitialGivenName { get; set; }

    [Parameter] public string? InitialFamilyName { get; set; }

    [Parameter] public DateOnly? InitialBirthDate { get; set; }

    [Parameter] public string NoMatchesMessage { get; set; } = "No matching records found in the National Register.";

    [Parameter] public bool ShowBirthDateColumn { get; set; } = true;

    [Parameter] public bool ShowMatchScore { get; set; }

    [Parameter] public bool ShowFormattedNumbers { get; set; }

    [Parameter] public string NumberColumnTitle { get; set; } = "Number";

    [Parameter] public int PageSize { get; set; } = 25;

    [Parameter] [EditorRequired] public Func<NrSearchFormCriteria, Task<NationalRegisterSearchResult>> SearchAsync { get; set; } = null!;

    [Parameter] public RenderFragment? LeadContent { get; set; }

    [Parameter] public RenderFragment<NationalRegisterSearchMatch>? RowActions { get; set; }

    private bool _searching;
    private bool _searched;
    private string? _error;
    private string _givenName = string.Empty;
    private string _familyName = string.Empty;
    private DateOnly? _birthDate;
    private int _page = 1;
    private int _pageSize = 25;
    private int _totalCount;
    private IReadOnlyList<NationalRegisterSearchMatch> _matches = [];

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)_pageSize));

    protected override void OnParametersSet()
    {
        _givenName = InitialGivenName ?? string.Empty;
        _familyName = InitialFamilyName ?? string.Empty;
        _birthDate = InitialBirthDate;
        _pageSize = PageSize;
    }

    private async Task Search()
    {
        await LoadPageAsync(1);
    }

    private async Task OnPageChanged(int page)
    {
        await LoadPageAsync(page);
    }

    private async Task LoadPageAsync(int page)
    {
        _searching = true;
        _error = null;

        try
        {
            var criteria = new NrSearchFormCriteria(
                string.IsNullOrWhiteSpace(_givenName) ? null : _givenName.Trim(),
                string.IsNullOrWhiteSpace(_familyName) ? null : _familyName.Trim(),
                _birthDate,
                page,
                _pageSize);

            var result = await SearchAsync(criteria);
            _matches = result.Matches;
            _totalCount = result.TotalCount;
            _page = result.Page;
            _pageSize = result.PageSize;
            _searched = true;
        }
        catch (ValidationException ex)
        {
            _error = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        finally
        {
            _searching = false;
        }
    }

    private string GetResultsRangeLabel()
    {
        if (_totalCount == 0)
        {
            return "No results";
        }

        var start = (_page - 1) * _pageSize + 1;
        var end = Math.Min(_page * _pageSize, _totalCount);
        return $"{start}–{end} of {_totalCount}";
    }

}