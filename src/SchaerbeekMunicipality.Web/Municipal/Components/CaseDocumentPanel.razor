<div class="registration-case-document-panel">
    @if (CanEdit && UploadContent is not null)
    {
        <AppSection>
            @UploadContent
        </AppSection>
    }

    @if (Documents.Count > 0)
    {
        <AppSection>
            <AppCard Title="Attached documents" Outlined="true">
                @if (_selectedDocumentId is null)
                {
                    <AppInfoBox Class="mb-3">
                        Click a document to open a preview.
                    </AppInfoBox>
                }

                <MudList T="Guid" Dense="true" Class="pa-0">
                    @foreach (var doc in Documents)
                    {
                        <MudListItem T="Guid"
                                     Value="doc.Id"
                                     Icon="@Icons.Material.Outlined.AttachFile"
                                     Class="@GetListItemClass(doc.Id)"
                                     OnClick="@(() => SelectDocument(doc.Id))">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-grow-1">
                                <div>
                                    @FormatListLabel(doc)
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @doc.UploadedAt.LocalDateTime.ToString("g")
                                    </MudText>
                                </div>
                                @if (CanEdit)
                                {
                                    <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   aria-label="@($"Remove {doc.FileName}")"
                                                   OnClick="@(() => OnRemoveDocument.InvokeAsync(doc.Id))"/>
                                }
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            </AppCard>
        </AppSection>

        @if (_selectedDocument is not null)
        {
            <AppSection>
                <AppCard Title="Preview" Outlined="true">
                    <HeaderActions>
                        <MudButton Variant="Variant.Text"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Outlined.Download"
                                   Href="@GetDocumentUrl(_selectedDocument.Id)"
                                   Target="_blank">
                            Download
                        </MudButton>
                    </HeaderActions>
                    <ChildContent>
                        <AppFilePreview Url="@GetDocumentUrl(_selectedDocument.Id)"
                                        FileName="@_selectedDocument.FileName"/>
                    </ChildContent>
                </AppCard>
            </AppSection>
        }
    }
    else if (ShowEmptyState)
    {
        <AppSection>
            <AppCard Outlined="true">
                <AppEmptyState Icon="@Icons.Material.Outlined.Description"
                               Title="@EmptyTitle"
                               Description="@EmptyDescription"/>
            </AppCard>
        </AppSection>
    }
</div>

@code {
    [Parameter] [EditorRequired] public IReadOnlyList<CaseDocumentItem> Documents { get; set; } = [];

    [Parameter] [EditorRequired] public Func<Guid, string> GetDocumentUrl { get; set; } = null!;

    [Parameter] public bool CanEdit { get; set; }

    [Parameter] public bool ShowEmptyState { get; set; } = true;

    [Parameter] public string EmptyTitle { get; set; } = "No documents attached";

    [Parameter] public string EmptyDescription { get; set; } = "Upload a supporting document.";

    [Parameter] public EventCallback<Guid> OnRemoveDocument { get; set; }

    [Parameter] public RenderFragment? UploadContent { get; set; }

    private Guid? _selectedDocumentId;

    private CaseDocumentItem? _selectedDocument =>
        _selectedDocumentId is null
            ? null
            : Documents.FirstOrDefault(d => d.Id == _selectedDocumentId);

    protected override void OnParametersSet()
    {
        if (Documents.Count == 0)
        {
            _selectedDocumentId = null;
            return;
        }

        if (_selectedDocumentId is not null && Documents.All(d => d.Id != _selectedDocumentId))
        {
            _selectedDocumentId = null;
        }
    }

    private void SelectDocument(Guid documentId)
    {
        _selectedDocumentId = documentId;
    }

    private string GetListItemClass(Guid documentId)
    {
        var classes = new List<string> { "registration-case-document-list-item" };
        if (documentId == _selectedDocumentId)
        {
            classes.Add("registration-case-document-list-item--selected");
        }

        return string.Join(' ', classes);
    }

    private static string FormatListLabel(CaseDocumentItem doc)
    {
        return string.IsNullOrWhiteSpace(doc.TypeLabel)
            ? doc.FileName
            : $"{doc.TypeLabel} — {doc.FileName}";
    }

}