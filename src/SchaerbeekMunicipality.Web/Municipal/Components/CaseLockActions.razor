@if (IsReadOnlyDueToLock)
{
    <MudButton Variant="Variant.Outlined" OnClick="OnTakeCase">Take case</MudButton>
}
else if (CanEdit)
{
    <MudButton Variant="Variant.Outlined" OnClick="OnReleaseLock">Release lock</MudButton>
}

@code {
    [Parameter]
    public bool IsReadOnlyDueToLock { get; set; }

    [Parameter]
    public bool CanEdit { get; set; }

    [Parameter]
    public EventCallback OnTakeCase { get; set; }

    [Parameter]
    public EventCallback OnReleaseLock { get; set; }
}
